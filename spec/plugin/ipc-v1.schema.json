{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/ipc-v1.schema.json",
  "title": "ReDevPlugin Rust IPC v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["ipc_version", "frame_type", "request_id"],
  "properties": {
    "ipc_version": { "const": "rust-ipc-v1" },
    "frame_type": {
      "enum": ["hello", "hello_ack", "heartbeat", "lease_grant", "invoke_worker", "invoke_worker_result", "open_handle", "close_handle", "revoke_epoch", "revoke_epoch_ack", "diagnostic"]
    },
    "request_id": { "type": "string", "minLength": 1 },
    "runtime_generation_id": { "type": "string" },
    "payload": true
  },
  "allOf": [
    {
      "if": { "properties": { "frame_type": { "const": "hello" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target", "host_process_id", "host_ipc_version", "host_wasm_abi", "started_unix_nano"],
            "properties": {
              "target": {
                "type": "object",
                "additionalProperties": false,
                "required": ["os", "arch"],
                "properties": {
                  "os": { "type": "string", "minLength": 1 },
                  "arch": { "type": "string", "minLength": 1 }
                }
              },
              "host_process_id": { "type": "integer", "minimum": 1 },
              "host_ipc_version": { "const": "rust-ipc-v1" },
              "host_wasm_abi": { "const": "redeven-wasm-worker-v1" },
              "started_unix_nano": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "hello_ack" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["runtime_version", "rust_ipc_version", "wasm_abi_version"],
            "properties": {
              "runtime_version": { "type": "string", "minLength": 1 },
              "rust_ipc_version": { "const": "rust-ipc-v1" },
              "wasm_abi_version": { "const": "redeven-wasm-worker-v1" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "invoke_worker" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["lease", "method", "invocation"],
            "properties": {
              "lease": {
                "type": "object",
                "additionalProperties": true,
                "required": ["lease_id", "lease_token", "runtime_generation_id", "plugin_instance_id"],
                "properties": {
                  "lease_id": { "type": "string", "minLength": 1 },
                  "lease_token": { "type": "string", "minLength": 1 },
                  "runtime_generation_id": { "type": "string", "minLength": 1 },
                  "plugin_instance_id": { "type": "string", "minLength": 1 },
                  "policy_revision": { "type": "integer", "minimum": 0 },
                  "management_revision": { "type": "integer", "minimum": 0 },
                  "revoke_epoch": { "type": "integer", "minimum": 0 },
                  "expires_at": { "type": "string", "format": "date-time" }
                }
              },
              "method": { "type": "string", "minLength": 1 },
              "invocation": {
                "$ref": "https://schemas.redevplugin.dev/plugin/worker-invocation-v1.schema.json"
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "invoke_worker_result" } }, "required": ["frame_type"] },
      "then": { "$ref": "#/$defs/runtime_response_frame" }
    },
    {
      "if": { "properties": { "frame_type": { "const": "open_handle" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/open_handle_request_payload" },
              { "$ref": "#/$defs/open_handle_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "revoke_epoch" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["plugin_instance_id", "revoke_epoch"],
            "properties": {
              "plugin_instance_id": { "type": "string", "minLength": 1 },
              "revoke_epoch": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "revoke_epoch_ack" } }, "required": ["frame_type"] },
      "then": { "$ref": "#/$defs/runtime_response_frame" }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "worker_artifact_path": {
      "type": "string",
      "pattern": "^workers/(?!.*(?:^|/)\\.)(?!.*//)(?!.*\\\\).+\\.wasm$"
    },
    "open_handle_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package_hash", "artifact", "artifact_sha256"],
      "properties": {
        "package_hash": { "$ref": "#/$defs/sha256" },
        "artifact": { "$ref": "#/$defs/worker_artifact_path" },
        "artifact_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "open_handle_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "package_hash": { "$ref": "#/$defs/sha256" },
        "artifact": { "$ref": "#/$defs/worker_artifact_path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "content_base64": { "type": "string", "contentEncoding": "base64" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "runtime_response_frame": {
      "required": ["runtime_generation_id", "payload"],
      "properties": {
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok"],
          "properties": {
            "ok": { "type": "boolean" },
            "result": true,
            "error": { "type": "string" },
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      }
    }
  }
}
