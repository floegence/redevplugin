{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/ipc-v1.schema.json",
  "title": "ReDevPlugin Rust IPC v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["ipc_version", "frame_type", "request_id"],
  "properties": {
    "ipc_version": { "const": "rust-ipc-v1" },
    "frame_type": {
      "enum": ["hello", "hello_ack", "heartbeat", "lease_grant", "invoke_worker", "invoke_worker_result", "open_handle", "close_handle", "validate_handle_grant", "storage_file", "storage_kv", "storage_sqlite", "network_grant", "network_execute", "revoke_epoch", "revoke_epoch_ack", "diagnostic"]
    },
    "request_id": { "type": "string", "minLength": 1 },
    "runtime_generation_id": { "type": "string" },
    "payload": true
  },
  "allOf": [
    {
      "if": { "properties": { "frame_type": { "const": "hello" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target", "host_process_id", "host_ipc_version", "host_wasm_abi", "started_unix_nano", "channel_nonce"],
            "properties": {
              "target": {
                "type": "object",
                "additionalProperties": false,
                "required": ["os", "arch"],
                "properties": {
                  "os": { "type": "string", "minLength": 1 },
                  "arch": { "type": "string", "minLength": 1 }
                }
              },
              "host_process_id": { "type": "integer", "minimum": 1 },
              "host_ipc_version": { "const": "rust-ipc-v1" },
              "host_wasm_abi": { "const": "redevplugin-wasm-worker-v1" },
              "started_unix_nano": { "type": "integer", "minimum": 1 },
              "channel_nonce": { "type": "string", "minLength": 16 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "hello_ack" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["runtime_version", "rust_ipc_version", "wasm_abi_version", "channel_nonce"],
            "properties": {
              "runtime_version": { "type": "string", "minLength": 1 },
              "rust_ipc_version": { "const": "rust-ipc-v1" },
              "wasm_abi_version": { "const": "redevplugin-wasm-worker-v1" },
              "channel_nonce": { "type": "string", "minLength": 16 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "invoke_worker" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["lease", "method", "invocation"],
            "properties": {
              "lease": {
                "type": "object",
                "additionalProperties": true,
                "required": ["lease_id", "lease_token", "lease_nonce", "runtime_generation_id", "plugin_instance_id"],
                "properties": {
                  "lease_id": { "type": "string", "minLength": 1 },
                  "lease_token": { "type": "string", "minLength": 1 },
                  "lease_nonce": { "type": "string", "minLength": 16 },
                  "runtime_generation_id": { "type": "string", "minLength": 1 },
                  "plugin_instance_id": { "type": "string", "minLength": 1 },
                  "policy_revision": { "type": "integer", "minimum": 0 },
                  "management_revision": { "type": "integer", "minimum": 0 },
                  "revoke_epoch": { "type": "integer", "minimum": 0 },
                  "expires_at": { "type": "string", "format": "date-time" }
                }
              },
              "method": { "type": "string", "minLength": 1 },
              "invocation": {
                "$ref": "https://schemas.redevplugin.dev/plugin/worker-invocation-v1.schema.json"
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "invoke_worker_result" } }, "required": ["frame_type"] },
      "then": { "$ref": "#/$defs/runtime_response_frame" }
    },
    {
      "if": { "properties": { "frame_type": { "const": "open_handle" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/open_handle_request_payload" },
              { "$ref": "#/$defs/open_handle_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "validate_handle_grant" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/validate_handle_grant_request_payload" },
              { "$ref": "#/$defs/validate_handle_grant_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "storage_file" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/storage_file_request_payload" },
              { "$ref": "#/$defs/storage_file_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "storage_kv" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/storage_kv_request_payload" },
              { "$ref": "#/$defs/storage_kv_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "storage_sqlite" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/storage_sqlite_request_payload" },
              { "$ref": "#/$defs/storage_sqlite_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "network_grant" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/network_grant_request_payload" },
              { "$ref": "#/$defs/network_grant_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "network_execute" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/network_execute_request_payload" },
              { "$ref": "#/$defs/network_execute_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "revoke_epoch" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["plugin_instance_id", "revoke_epoch"],
            "properties": {
              "plugin_instance_id": { "type": "string", "minLength": 1 },
              "revoke_epoch": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "revoke_epoch_ack" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": { "$ref": "#/$defs/revoke_epoch_ack_response_payload" }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "worker_artifact_path": {
      "type": "string",
      "pattern": "^workers/(?!.*(?:^|/)\\.)(?!.*//)(?!.*\\\\).+\\.wasm$"
    },
    "open_handle_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package_hash", "artifact", "artifact_sha256"],
      "properties": {
        "package_hash": { "$ref": "#/$defs/sha256" },
        "artifact": { "$ref": "#/$defs/worker_artifact_path" },
        "artifact_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "open_handle_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "package_hash": { "$ref": "#/$defs/sha256" },
        "artifact": { "$ref": "#/$defs/worker_artifact_path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "content_base64": { "type": "string", "contentEncoding": "base64" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "validate_handle_grant_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handle_grant_token",
        "plugin_instance_id",
        "active_fingerprint",
        "runtime_generation_id",
        "handle_id",
        "method",
        "policy_revision",
        "management_revision",
        "revoke_epoch"
      ],
      "properties": {
        "handle_grant_token": { "type": "string", "minLength": 1 },
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "active_fingerprint": { "type": "string", "minLength": 1 },
        "runtime_instance_id": { "type": "string" },
        "runtime_generation_id": { "type": "string", "minLength": 1 },
        "runtime_shard_id": { "type": "string" },
        "handle_id": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "policy_revision": { "type": "integer", "minimum": 0 },
        "management_revision": { "type": "integer", "minimum": 0 },
        "revoke_epoch": { "type": "integer", "minimum": 0 }
      }
    },
    "validate_handle_grant_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "handle_grant_id": { "type": "string" },
        "handle_id": { "type": "string" },
        "method": { "type": "string" },
        "runtime_generation_id": { "type": "string" },
        "max_bytes_per_second": { "type": "integer", "minimum": 0 },
        "max_total_bytes": { "type": "integer", "minimum": 0 },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "storage_file_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handle_grant_token",
        "plugin_instance_id",
        "active_fingerprint",
        "runtime_generation_id",
        "handle_id",
        "method",
        "policy_revision",
        "management_revision",
        "revoke_epoch",
        "operation",
        "store_id"
      ],
      "properties": {
        "handle_grant_token": { "type": "string", "minLength": 1 },
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "active_fingerprint": { "type": "string", "minLength": 1 },
        "runtime_instance_id": { "type": "string" },
        "runtime_generation_id": { "type": "string", "minLength": 1 },
        "runtime_shard_id": { "type": "string" },
        "handle_id": { "type": "string", "pattern": "^storage:[A-Za-z0-9_.-]+$" },
        "method": { "const": "storage.files" },
        "policy_revision": { "type": "integer", "minimum": 0 },
        "management_revision": { "type": "integer", "minimum": 0 },
        "revoke_epoch": { "type": "integer", "minimum": 0 },
        "operation": { "enum": ["read", "write", "delete", "list"] },
        "store_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
        "path": { "type": "string" },
        "data_base64": { "type": "string", "contentEncoding": "base64" },
        "max_bytes": { "type": "integer", "minimum": 0 },
        "max_entries": { "type": "integer", "minimum": 0 },
        "recursive": { "type": "boolean" }
      }
    },
    "storage_file_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "path": { "type": "string" },
        "data_base64": { "type": "string", "contentEncoding": "base64" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/storage_file_entry" }
        },
        "usage": { "$ref": "#/$defs/storage_usage" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "storage_file_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "dir", "updated_at"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "dir": { "type": "boolean" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "storage_kv_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handle_grant_token",
        "plugin_instance_id",
        "active_fingerprint",
        "runtime_generation_id",
        "handle_id",
        "method",
        "policy_revision",
        "management_revision",
        "revoke_epoch",
        "operation",
        "store_id"
      ],
      "properties": {
        "handle_grant_token": { "type": "string", "minLength": 1 },
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "active_fingerprint": { "type": "string", "minLength": 1 },
        "runtime_instance_id": { "type": "string" },
        "runtime_generation_id": { "type": "string", "minLength": 1 },
        "runtime_shard_id": { "type": "string" },
        "handle_id": { "type": "string", "pattern": "^storage:[A-Za-z0-9_.-]+$" },
        "method": { "const": "storage.kv" },
        "policy_revision": { "type": "integer", "minimum": 0 },
        "management_revision": { "type": "integer", "minimum": 0 },
        "revoke_epoch": { "type": "integer", "minimum": 0 },
        "operation": { "enum": ["get", "put", "delete", "list"] },
        "store_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
        "key": { "type": "string" },
        "value_base64": { "type": "string", "contentEncoding": "base64" },
        "prefix": { "type": "string" },
        "max_bytes": { "type": "integer", "minimum": 0 },
        "max_entries": { "type": "integer", "minimum": 0 }
      }
    },
    "storage_kv_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "key": { "type": "string" },
        "value_base64": { "type": "string", "contentEncoding": "base64" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "prefix": { "type": "string" },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/storage_kv_entry" }
        },
        "usage": { "$ref": "#/$defs/storage_usage" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "storage_kv_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "size_bytes", "updated_at"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "storage_sqlite_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handle_grant_token",
        "plugin_instance_id",
        "active_fingerprint",
        "runtime_generation_id",
        "handle_id",
        "method",
        "policy_revision",
        "management_revision",
        "revoke_epoch",
        "operation",
        "store_id",
        "sql"
      ],
      "properties": {
        "handle_grant_token": { "type": "string", "minLength": 1 },
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "active_fingerprint": { "type": "string", "minLength": 1 },
        "runtime_instance_id": { "type": "string" },
        "runtime_generation_id": { "type": "string", "minLength": 1 },
        "runtime_shard_id": { "type": "string" },
        "handle_id": { "type": "string", "pattern": "^storage:[A-Za-z0-9_.-]+$" },
        "method": { "const": "storage.sqlite" },
        "policy_revision": { "type": "integer", "minimum": 0 },
        "management_revision": { "type": "integer", "minimum": 0 },
        "revoke_epoch": { "type": "integer", "minimum": 0 },
        "operation": { "enum": ["exec", "query"] },
        "store_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
        "database": { "type": "string" },
        "sql": { "type": "string", "minLength": 1 },
        "args": {
          "type": "array",
          "items": { "$ref": "#/$defs/storage_sqlite_value" }
        },
        "max_rows": { "type": "integer", "minimum": 0 },
        "max_response_bytes": { "type": "integer", "minimum": 0 },
        "timeout_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "storage_sqlite_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "database": { "type": "string" },
        "rows_affected": { "type": "integer", "minimum": 0 },
        "last_insert_id": { "type": "integer", "minimum": 0 },
        "columns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "$ref": "#/$defs/storage_sqlite_value" }
          }
        },
        "usage": { "$ref": "#/$defs/storage_usage" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "storage_sqlite_value": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "null": { "type": "boolean" },
        "int": { "type": "integer" },
        "float": { "type": "number" },
        "text": { "type": "string" },
        "blob_base64": { "type": "string", "contentEncoding": "base64" }
      }
    },
    "storage_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plugin_instance_id", "store_id", "usage_bytes", "quota_bytes"],
      "properties": {
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "store_id": { "type": "string", "minLength": 1 },
        "usage_bytes": { "type": "integer", "minimum": 0 },
        "quota_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "network_grant_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_instance_id",
        "active_fingerprint",
        "runtime_generation_id",
        "policy_revision",
        "management_revision",
        "revoke_epoch",
        "connector_id",
        "transport",
        "destination"
      ],
      "properties": {
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "active_fingerprint": { "type": "string", "minLength": 1 },
        "runtime_instance_id": { "type": "string" },
        "runtime_generation_id": { "type": "string", "minLength": 1 },
        "runtime_shard_id": { "type": "string" },
        "policy_revision": { "type": "integer", "minimum": 0 },
        "management_revision": { "type": "integer", "minimum": 0 },
        "revoke_epoch": { "type": "integer", "minimum": 0 },
        "connector_id": { "type": "string", "minLength": 1 },
        "transport": { "enum": ["http", "websocket", "tcp", "udp"] },
        "destination": { "type": "string", "minLength": 1 },
        "ttl_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "network_grant_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "grant_id": { "type": "string", "pattern": "^netgrant_[0-9a-f]{32}$" },
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "active_fingerprint": { "type": "string", "minLength": 1 },
        "policy_revision": { "type": "integer", "minimum": 0 },
        "management_revision": { "type": "integer", "minimum": 0 },
        "revoke_epoch": { "type": "integer", "minimum": 0 },
        "connector_id": { "type": "string", "minLength": 1 },
        "transport": { "enum": ["http", "websocket", "tcp", "udp"] },
        "destination": { "$ref": "#/$defs/network_destination" },
        "runtime_generation_id": { "type": "string" },
        "target_classifier_version": { "const": "target-classifier-v1" },
        "expires_at": { "type": "string", "format": "date-time" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "network_execute_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_instance_id",
        "active_fingerprint",
        "runtime_generation_id",
        "policy_revision",
        "management_revision",
        "revoke_epoch",
        "connector_id",
        "transport",
        "destination"
      ],
      "properties": {
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "active_fingerprint": { "type": "string", "minLength": 1 },
        "runtime_instance_id": { "type": "string" },
        "runtime_generation_id": { "type": "string", "minLength": 1 },
        "runtime_shard_id": { "type": "string" },
        "policy_revision": { "type": "integer", "minimum": 0 },
        "management_revision": { "type": "integer", "minimum": 0 },
        "revoke_epoch": { "type": "integer", "minimum": 0 },
        "connector_id": { "type": "string", "minLength": 1 },
        "transport": { "enum": ["http", "websocket", "tcp", "udp"] },
        "destination": { "type": "string", "minLength": 1 },
        "ttl_ms": { "type": "integer", "minimum": 0 },
        "operation": { "enum": ["http", "websocket_round_trip", "tcp_round_trip", "udp_round_trip"] },
        "method": { "type": "string", "minLength": 1 },
        "path": { "type": "string" },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "message_type": { "enum": ["text", "binary"] },
        "body_base64": { "type": "string", "contentEncoding": "base64" },
        "payload_base64": { "type": "string", "contentEncoding": "base64" },
        "max_request_bytes": { "type": "integer", "minimum": 0 },
        "max_response_bytes": { "type": "integer", "minimum": 0 },
        "timeout_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "network_execute_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "transport": { "enum": ["http", "websocket", "tcp", "udp"] },
        "destination": { "$ref": "#/$defs/network_destination" },
        "status_code": { "type": "integer", "minimum": 100, "maximum": 599 },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "message_type": { "enum": ["text", "binary"] },
        "body_base64": { "type": "string", "contentEncoding": "base64" },
        "payload_base64": { "type": "string", "contentEncoding": "base64" },
        "grant_id": { "type": "string", "pattern": "^netgrant_[0-9a-f]{32}$" },
        "connector_id": { "type": "string", "minLength": 1 },
        "runtime_generation_id": { "type": "string" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "network_destination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transport", "host", "port"],
      "properties": {
        "transport": { "enum": ["http", "websocket", "tcp", "udp"] },
        "scheme": { "enum": ["http", "https", "ws", "wss"] },
        "host": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "revoke_epoch_ack_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "result": { "$ref": "#/$defs/revoke_epoch_ack_result" },
        "error": { "type": "string" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "ok": { "const": true } },
            "required": ["ok"]
          },
          "then": { "required": ["result"] }
        },
        {
          "if": {
            "properties": { "ok": { "const": false } },
            "required": ["ok"]
          },
          "then": { "required": ["code", "message"] }
        }
      ]
    },
    "revoke_epoch_ack_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_instance_id",
        "revoke_epoch",
        "closed_actor_count",
        "closed_socket_count",
        "closed_stream_count",
        "closed_storage_handle_count"
      ],
      "properties": {
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "revoke_epoch": { "type": "integer", "minimum": 0 },
        "closed_actor_count": { "type": "integer", "minimum": 0 },
        "closed_socket_count": { "type": "integer", "minimum": 0 },
        "closed_stream_count": { "type": "integer", "minimum": 0 },
        "closed_storage_handle_count": { "type": "integer", "minimum": 0 }
      }
    },
    "runtime_response_frame": {
      "required": ["runtime_generation_id", "payload"],
      "properties": {
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok"],
          "properties": {
            "ok": { "type": "boolean" },
            "result": true,
            "error": { "type": "string" },
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      }
    }
  }
}
