{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/trusted-time-evidence-v1.schema.json",
  "title": "ReDevPlugin trusted time transparency evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "leaf",
    "leaf_sha256",
    "integrated_time",
    "signed_entry_timestamp",
    "checkpoint",
    "leaf_index",
    "inclusion_proof",
    "consistency_proof"
  ],
  "properties": {
    "schema_version": { "const": "redevplugin.trusted_time_evidence.v1" },
    "kind": { "const": "transparency" },
    "leaf": { "$ref": "#/$defs/leaf" },
    "leaf_sha256": { "$ref": "#/$defs/sha256" },
    "integrated_time": { "type": "string", "format": "date-time", "maxLength": 35 },
    "signed_entry_timestamp": { "$ref": "#/$defs/signature" },
    "checkpoint": { "$ref": "#/$defs/checkpoint" },
    "leaf_index": { "type": "integer", "minimum": 0, "maximum": 9007199254740990 },
    "inclusion_proof": { "$ref": "#/$defs/proof" },
    "consistency_proof": { "$ref": "#/$defs/proof" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "leaf": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "source_id", "channel", "nonce", "minimum_time", "claimed_time", "request_sha256", "log_id"],
      "properties": {
        "schema_version": { "const": "redevplugin.trusted_time_leaf.v1" },
        "source_id": { "$ref": "#/$defs/id" },
        "channel": { "$ref": "#/$defs/id" },
        "nonce": { "type": "string", "pattern": "^[A-Za-z0-9_-]{43}$" },
        "minimum_time": { "type": "string", "format": "date-time", "maxLength": 35 },
        "claimed_time": { "type": "string", "format": "date-time", "maxLength": 35 },
        "request_sha256": { "$ref": "#/$defs/sha256" },
        "log_id": { "$ref": "#/$defs/id" }
      }
    },
    "signature": { "type": "string", "pattern": "^[A-Za-z0-9+/]{86}==$" },
    "proof": {
      "type": "array",
      "maxItems": 64,
      "items": { "$ref": "#/$defs/sha256" }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "log_id", "tree_size", "root_hash", "checkpoint_time", "key_id", "signature"],
      "properties": {
        "schema_version": { "const": "redevplugin.trusted_time_checkpoint.v1" },
        "log_id": { "$ref": "#/$defs/id" },
        "tree_size": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "root_hash": { "$ref": "#/$defs/sha256" },
        "checkpoint_time": { "type": "string", "format": "date-time", "maxLength": 35 },
        "key_id": { "$ref": "#/$defs/id" },
        "signature": { "$ref": "#/$defs/signature" }
      }
    }
  }
}
