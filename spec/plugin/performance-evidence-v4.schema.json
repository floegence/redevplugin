{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/performance-evidence-v4.schema.json",
  "title": "ReDevPlugin release performance evidence v4",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_version",
    "source_commit",
    "generated_at",
    "environment",
    "scenarios",
    "comparisons",
    "contract_hashes"
  ],
  "properties": {
    "schema_version": { "const": "redevplugin.performance_evidence.v4" },
    "release_version": { "$ref": "#/$defs/semver" },
    "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "generated_at": { "type": "string", "format": "date-time" },
    "environment": { "$ref": "#/$defs/environment" },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/scenario" }
    },
    "comparisons": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/comparison" }
    },
    "contract_hashes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/contract_hash" }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch", "logical_cpus", "go_version", "node_version", "rustc_version", "chromium_version"],
      "properties": {
        "os": { "type": "string", "minLength": 1 },
        "arch": { "type": "string", "minLength": 1 },
        "logical_cpus": { "type": "integer", "minimum": 1 },
        "go_version": { "type": "string", "minLength": 1 },
        "node_version": { "type": "string", "minLength": 1 },
        "rustc_version": { "type": "string", "minLength": 1 },
        "chromium_version": { "type": "string", "minLength": 1 }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "gate", "status", "sample_count", "metrics"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]+$" },
        "gate": { "enum": ["fast", "smoke", "weekly", "full", "release"] },
        "status": { "const": "pass" },
        "sample_count": { "type": "integer", "minimum": 1 },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/metric" }
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "unit", "observed", "limit", "comparator"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9._-]+$" },
        "unit": { "enum": ["milliseconds", "count", "bytes", "queries", "long_tasks", "basis_points"] },
        "observed": { "type": "number", "minimum": 0 },
        "limit": { "type": "number", "minimum": 0 },
        "comparator": { "enum": ["lte", "eq"] }
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "baseline_release",
        "baseline_commit",
        "candidate_commit",
        "accepted_attempt",
        "attempts"
      ],
      "properties": {
        "id": { "const": "httpadapter.route-authorization-v051" },
        "baseline_release": { "const": "0.5.1" },
        "baseline_commit": { "const": "3febcc59bbdb2118a4f105781b4c743bc11ba09f" },
        "candidate_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "accepted_attempt": { "type": "integer", "minimum": 1, "maximum": 3 },
        "attempts": { "type": "array" }
      },
      "oneOf": [
        {
          "properties": {
            "accepted_attempt": { "const": 1 },
            "attempts": {
              "minItems": 1,
              "maxItems": 1,
              "prefixItems": [{ "$ref": "#/$defs/comparison_attempt_1_qualified" }],
              "items": false
            }
          }
        },
        {
          "properties": {
            "accepted_attempt": { "const": 2 },
            "attempts": {
              "minItems": 2,
              "maxItems": 2,
              "prefixItems": [
                { "$ref": "#/$defs/comparison_attempt_1_noisy" },
                { "$ref": "#/$defs/comparison_attempt_2_qualified" }
              ],
              "items": false
            }
          }
        },
        {
          "properties": {
            "accepted_attempt": { "const": 3 },
            "attempts": {
              "minItems": 3,
              "maxItems": 3,
              "prefixItems": [
                { "$ref": "#/$defs/comparison_attempt_1_noisy" },
                { "$ref": "#/$defs/comparison_attempt_2_noisy" },
                { "$ref": "#/$defs/comparison_attempt_3_qualified" }
              ],
              "items": false
            }
          }
        }
      ]
    },
    "comparison_attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempt", "run_order", "environment", "runs", "noise_qualification", "attempt_sha256"],
      "properties": {
        "attempt": { "type": "integer", "minimum": 1, "maximum": 3 },
        "run_order": {
          "type": "array",
          "minItems": 18,
          "maxItems": 18,
          "prefixItems": [
            { "const": "baseline" }, { "const": "candidate" },
            { "const": "candidate" }, { "const": "baseline" },
            { "const": "baseline" }, { "const": "candidate" },
            { "const": "candidate" }, { "const": "baseline" },
            { "const": "baseline" }, { "const": "candidate" },
            { "const": "candidate" }, { "const": "baseline" },
            { "const": "baseline" }, { "const": "candidate" },
            { "const": "candidate" }, { "const": "baseline" },
            { "const": "baseline" }, { "const": "candidate" }
          ],
          "items": false
        },
        "environment": { "$ref": "#/$defs/route_authorization_environment" },
        "runs": {
          "type": "array",
          "minItems": 9,
          "maxItems": 9,
          "prefixItems": [
            { "$ref": "#/$defs/comparison_run_0_baseline" },
            { "$ref": "#/$defs/comparison_run_1_candidate" },
            { "$ref": "#/$defs/comparison_run_2_baseline" },
            { "$ref": "#/$defs/comparison_run_3_candidate" },
            { "$ref": "#/$defs/comparison_run_4_baseline" },
            { "$ref": "#/$defs/comparison_run_5_candidate" },
            { "$ref": "#/$defs/comparison_run_6_baseline" },
            { "$ref": "#/$defs/comparison_run_7_candidate" },
            { "$ref": "#/$defs/comparison_run_8_baseline" }
          ],
          "items": false
        },
        "noise_qualification": { "$ref": "#/$defs/noise_qualification" },
        "attempt_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "comparison_attempt_1_qualified": {
      "allOf": [
        { "$ref": "#/$defs/comparison_attempt" },
        { "properties": { "attempt": { "const": 1 }, "noise_qualification": { "properties": { "status": { "const": "qualified" } } } } }
      ]
    },
    "comparison_attempt_1_noisy": {
      "allOf": [
        { "$ref": "#/$defs/comparison_attempt" },
        { "properties": { "attempt": { "const": 1 }, "noise_qualification": { "properties": { "status": { "const": "noisy" } } } } }
      ]
    },
    "comparison_attempt_2_qualified": {
      "allOf": [
        { "$ref": "#/$defs/comparison_attempt" },
        { "properties": { "attempt": { "const": 2 }, "noise_qualification": { "properties": { "status": { "const": "qualified" } } } } }
      ]
    },
    "comparison_attempt_2_noisy": {
      "allOf": [
        { "$ref": "#/$defs/comparison_attempt" },
        { "properties": { "attempt": { "const": 2 }, "noise_qualification": { "properties": { "status": { "const": "noisy" } } } } }
      ]
    },
    "comparison_attempt_3_qualified": {
      "allOf": [
        { "$ref": "#/$defs/comparison_attempt" },
        { "properties": { "attempt": { "const": 3 }, "noise_qualification": { "properties": { "status": { "const": "qualified" } } } } }
      ]
    },
    "comparison_run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pair_index",
        "first_variant",
        "baseline_profile_sha256",
        "candidate_profile_sha256",
        "baseline_profile",
        "candidate_profile"
      ],
      "properties": {
        "pair_index": { "type": "integer", "minimum": 0, "maximum": 8 },
        "first_variant": { "enum": ["baseline", "candidate"] },
        "baseline_profile_sha256": { "$ref": "#/$defs/sha256" },
        "candidate_profile_sha256": { "$ref": "#/$defs/sha256" },
        "baseline_profile": { "$ref": "#/$defs/route_authorization_profile" },
        "candidate_profile": { "$ref": "#/$defs/route_authorization_profile" }
      }
    },
    "comparison_run_0_baseline": { "allOf": [{ "$ref": "#/$defs/comparison_run" }, { "properties": { "pair_index": { "const": 0 }, "first_variant": { "const": "baseline" } } }] },
    "comparison_run_1_candidate": { "allOf": [{ "$ref": "#/$defs/comparison_run" }, { "properties": { "pair_index": { "const": 1 }, "first_variant": { "const": "candidate" } } }] },
    "comparison_run_2_baseline": { "allOf": [{ "$ref": "#/$defs/comparison_run" }, { "properties": { "pair_index": { "const": 2 }, "first_variant": { "const": "baseline" } } }] },
    "comparison_run_3_candidate": { "allOf": [{ "$ref": "#/$defs/comparison_run" }, { "properties": { "pair_index": { "const": 3 }, "first_variant": { "const": "candidate" } } }] },
    "comparison_run_4_baseline": { "allOf": [{ "$ref": "#/$defs/comparison_run" }, { "properties": { "pair_index": { "const": 4 }, "first_variant": { "const": "baseline" } } }] },
    "comparison_run_5_candidate": { "allOf": [{ "$ref": "#/$defs/comparison_run" }, { "properties": { "pair_index": { "const": 5 }, "first_variant": { "const": "candidate" } } }] },
    "comparison_run_6_baseline": { "allOf": [{ "$ref": "#/$defs/comparison_run" }, { "properties": { "pair_index": { "const": 6 }, "first_variant": { "const": "baseline" } } }] },
    "comparison_run_7_candidate": { "allOf": [{ "$ref": "#/$defs/comparison_run" }, { "properties": { "pair_index": { "const": 7 }, "first_variant": { "const": "candidate" } } }] },
    "comparison_run_8_baseline": { "allOf": [{ "$ref": "#/$defs/comparison_run" }, { "properties": { "pair_index": { "const": 8 }, "first_variant": { "const": "baseline" } } }] },
    "noise_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reasons", "metrics"],
      "properties": {
        "status": { "enum": ["qualified", "noisy"] },
        "reasons": {
          "type": "array",
          "maxItems": 12,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^c(100|1000)\\.(batch_median_relative|batch_p95_relative)\\.(relative_mad|maximum_relative_deviation|order_bias)$" }
        },
        "metrics": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "prefixItems": [
            { "$ref": "#/$defs/noise_metric_c100_batch_median" },
            { "$ref": "#/$defs/noise_metric_c100_batch_p95" },
            { "$ref": "#/$defs/noise_metric_c1000_batch_median" },
            { "$ref": "#/$defs/noise_metric_c1000_batch_p95" }
          ],
          "items": false
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "qualified" } } },
          "then": { "properties": { "reasons": { "maxItems": 0 } } },
          "else": { "properties": { "reasons": { "minItems": 1 } } }
        }
      ]
    },
    "noise_metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "median_basis_points", "relative_mad_basis_points", "relative_mad_limit_basis_points",
        "maximum_relative_deviation_basis_points", "maximum_relative_deviation_limit_basis_points",
        "order_bias_basis_points", "order_bias_limit_basis_points"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^c(100|1000)\\.(batch_median_relative|batch_p95_relative)$" },
        "median_basis_points": { "type": "number", "exclusiveMinimum": 0 },
        "relative_mad_basis_points": { "type": "number", "minimum": 0 },
        "relative_mad_limit_basis_points": { "type": "number", "minimum": 0 },
        "maximum_relative_deviation_basis_points": { "type": "number", "minimum": 0 },
        "maximum_relative_deviation_limit_basis_points": { "type": "number", "minimum": 0 },
        "order_bias_basis_points": { "type": "number", "minimum": 0 },
        "order_bias_limit_basis_points": { "type": "number", "minimum": 0 }
      },
      "allOf": [
        {
          "if": { "properties": { "id": { "pattern": "\\.batch_median_relative$" } } },
          "then": {
            "properties": {
              "relative_mad_limit_basis_points": { "const": 750 },
              "maximum_relative_deviation_limit_basis_points": { "const": 2500 },
              "order_bias_limit_basis_points": { "const": 750 }
            }
          },
          "else": {
            "properties": {
              "relative_mad_limit_basis_points": { "const": 1250 },
              "maximum_relative_deviation_limit_basis_points": { "const": 5000 },
              "order_bias_limit_basis_points": { "const": 2000 }
            }
          }
        }
      ]
    },
    "noise_metric_c100_batch_median": { "allOf": [{ "$ref": "#/$defs/noise_metric" }, { "properties": { "id": { "const": "c100.batch_median_relative" } } }] },
    "noise_metric_c100_batch_p95": { "allOf": [{ "$ref": "#/$defs/noise_metric" }, { "properties": { "id": { "const": "c100.batch_p95_relative" } } }] },
    "noise_metric_c1000_batch_median": { "allOf": [{ "$ref": "#/$defs/noise_metric" }, { "properties": { "id": { "const": "c1000.batch_median_relative" } } }] },
    "noise_metric_c1000_batch_p95": { "allOf": [{ "$ref": "#/$defs/noise_metric" }, { "properties": { "id": { "const": "c1000.batch_p95_relative" } } }] },
    "route_authorization_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "variant", "commit", "environment", "warmup_count", "requests_per_sample", "measurements"],
      "properties": {
        "schema_version": { "const": "redevplugin.route_authorization_performance.v2" },
        "variant": { "enum": ["v0.5.1", "v0.6.0"] },
        "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "environment": { "$ref": "#/$defs/route_authorization_environment" },
        "warmup_count": { "const": 8 },
        "requests_per_sample": { "const": 32 },
        "measurements": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/route_authorization_measurement" }
        }
      }
    },
    "route_authorization_environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch", "logical_cpus", "gomaxprocs", "go_version"],
      "properties": {
        "os": { "type": "string", "minLength": 1 },
        "arch": { "type": "string", "minLength": 1 },
        "logical_cpus": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "gomaxprocs": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "go_version": { "type": "string", "minLength": 1 }
      }
    },
    "route_authorization_measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "concurrency",
        "batch_count",
        "sample_count",
        "median_nanoseconds",
        "p95_nanoseconds",
        "p99_nanoseconds",
        "batch_median_nanoseconds_per_request",
        "batch_p95_nanoseconds_per_request",
        "allocations_per_request",
        "bytes_per_request"
      ],
      "properties": {
        "concurrency": { "enum": [1, 100, 1000] },
        "batch_count": { "type": "integer", "minimum": 64, "maximum": 9007199254740991 },
        "sample_count": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "median_nanoseconds": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "p95_nanoseconds": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "p99_nanoseconds": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "batch_median_nanoseconds_per_request": { "type": "number", "exclusiveMinimum": 0 },
        "batch_p95_nanoseconds_per_request": { "type": "number", "exclusiveMinimum": 0 },
        "allocations_per_request": { "type": "number", "minimum": 0 },
        "bytes_per_request": { "type": "number", "minimum": 0 }
      }
    },
    "contract_hash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
