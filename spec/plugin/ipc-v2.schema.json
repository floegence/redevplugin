{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/ipc-v2.schema.json",
  "title": "ReDevPlugin Rust IPC v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["ipc_version", "frame_type", "request_id"],
  "properties": {
    "ipc_version": { "const": "rust-ipc-v2" },
    "frame_type": {
      "enum": ["hello", "hello_ack", "heartbeat", "invoke_worker", "invoke_worker_result", "open_handle", "validate_handle_grant", "storage_file", "storage_kv", "storage_sqlite", "network_grant", "network_execute", "revoke_epoch", "revoke_epoch_ack", "diagnostic"]
    },
    "request_id": { "type": "string", "minLength": 1 },
    "runtime_generation_id": { "type": "string" },
    "payload": true
  },
  "allOf": [
    {
      "if": { "properties": { "frame_type": { "const": "hello" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target", "host_process_id", "host_ipc_version", "host_wasm_abi", "started_unix_nano", "channel_nonce", "runtime_lease_public_keys"],
            "properties": {
              "target": {
                "type": "object",
                "additionalProperties": false,
                "required": ["os", "arch"],
                "properties": {
                  "os": { "type": "string", "minLength": 1 },
                  "arch": { "type": "string", "minLength": 1 }
                }
              },
              "host_process_id": { "type": "integer", "minimum": 1 },
              "host_ipc_version": { "const": "rust-ipc-v2" },
              "host_wasm_abi": { "const": "redevplugin-wasm-worker-v2" },
              "started_unix_nano": { "type": "integer", "minimum": 1 },
              "channel_nonce": { "type": "string", "minLength": 16 },
              "runtime_lease_public_keys": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["algorithm", "key_id", "public_key_base64"],
                  "properties": {
                    "algorithm": { "const": "ed25519" },
                    "key_id": { "type": "string", "minLength": 1 },
                    "public_key_base64": { "type": "string", "contentEncoding": "base64" }
                  }
                },
                "uniqueItems": true
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "hello_ack" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["runtime_version", "rust_ipc_version", "wasm_abi_version", "channel_nonce"],
            "properties": {
              "runtime_version": { "type": "string", "minLength": 1 },
              "rust_ipc_version": { "const": "rust-ipc-v2" },
              "wasm_abi_version": { "const": "redevplugin-wasm-worker-v2" },
              "channel_nonce": { "type": "string", "minLength": 16 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "heartbeat" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/heartbeat_request_payload" },
              { "$ref": "#/$defs/heartbeat_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "invoke_worker" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["lease", "method", "invocation"],
            "properties": {
              "lease": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "lease_id",
                  "token_id",
                  "lease_nonce",
                  "runtime_generation_id",
                  "plugin_instance_id",
                  "plugin_id",
                  "plugin_version",
                  "active_fingerprint",
                  "owner_env_hash",
                  "issued_at_unix_ms",
                  "method",
                  "effect",
                  "execution",
                  "audit_correlation_id",
                  "target_descriptor_hashes",
                  "limits",
                  "policy_revision",
                  "management_revision",
                  "revoke_epoch",
                  "runtime_shard_id",
                  "runtime_instance_id",
                  "ipc_channel_id",
                  "connection_nonce",
                  "key_id",
                  "signature",
                  "expires_at_unix_ms"
                ],
                "properties": {
                  "lease_id": { "type": "string", "minLength": 1 },
                  "token_id": { "type": "string", "minLength": 1 },
                  "lease_nonce": { "type": "string", "minLength": 16 },
                  "runtime_generation_id": { "type": "string", "minLength": 1 },
                  "plugin_instance_id": { "type": "string", "minLength": 1 },
                  "plugin_id": { "type": "string", "minLength": 1 },
                  "plugin_version": { "type": "string", "minLength": 1 },
                  "active_fingerprint": { "type": "string", "minLength": 1 },
                  "issued_at_unix_ms": { "type": "integer", "minimum": 1 },
                  "method": { "type": "string", "minLength": 1 },
                  "effect": { "enum": ["read", "write", "execute", "delete", "admin"] },
                  "execution": { "enum": ["sync", "operation", "subscription"] },
                  "operation_id": { "type": "string", "minLength": 1 },
                  "stream_id": { "type": "string", "minLength": 1 },
                  "audit_correlation_id": { "type": "string", "minLength": 1 },
                  "surface_instance_id": { "type": "string", "minLength": 1 },
                  "owner_session_hash": { "type": "string", "minLength": 1 },
                  "owner_user_hash": { "type": "string", "minLength": 1 },
                  "owner_env_hash": { "type": "string", "minLength": 1 },
                  "session_channel_id_hash": { "type": "string", "minLength": 1 },
                  "bridge_channel_id": { "type": "string", "minLength": 1 },
                  "target_descriptor_hashes": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 },
                    "uniqueItems": true
                  },
                  "limits": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["timeout_ms", "memory_bytes", "max_payload_bytes", "max_stream_bytes_per_sec"],
                    "properties": {
                      "timeout_ms": { "type": "integer", "minimum": 0 },
                      "memory_bytes": { "type": "integer", "minimum": 1, "maximum": 268435456 },
                      "max_payload_bytes": { "type": "integer", "minimum": 0 },
                      "max_stream_bytes_per_sec": { "type": "integer", "minimum": 0 }
                    }
                  },
                  "policy_revision": { "type": "integer", "minimum": 0 },
                  "management_revision": { "type": "integer", "minimum": 0 },
                  "revoke_epoch": { "type": "integer", "minimum": 0 },
                  "runtime_shard_id": { "type": "string", "minLength": 1 },
                  "runtime_instance_id": { "type": "string", "minLength": 1 },
                  "ipc_channel_id": { "type": "string", "minLength": 1 },
                  "connection_nonce": { "type": "string", "minLength": 16 },
                  "key_id": { "type": "string", "minLength": 1 },
                  "signature": { "type": "string", "pattern": "^ed25519:.+" },
                  "expires_at_unix_ms": { "type": "integer", "minimum": 1 }
                },
                "allOf": [
                  {
                    "if": { "properties": { "execution": { "const": "sync" } }, "required": ["execution"] },
                    "then": { "not": { "anyOf": [{ "required": ["operation_id"] }, { "required": ["stream_id"] }] } }
                  },
                  {
                    "if": { "properties": { "execution": { "const": "operation" } }, "required": ["execution"] },
                    "then": { "required": ["operation_id"], "not": { "required": ["stream_id"] } }
                  },
                  {
                    "if": { "properties": { "execution": { "const": "subscription" } }, "required": ["execution"] },
                    "then": { "required": ["operation_id", "stream_id"] }
                  }
                ]
              },
              "method": { "type": "string", "minLength": 1 },
              "invocation": {
                "$ref": "https://schemas.redevplugin.dev/plugin/worker-invocation-v2.schema.json"
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "invoke_worker_result" } }, "required": ["frame_type"] },
      "then": { "$ref": "#/$defs/runtime_response_frame" }
    },
    {
      "if": { "properties": { "frame_type": { "const": "open_handle" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/open_handle_request_payload" },
              { "$ref": "#/$defs/open_handle_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "validate_handle_grant" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/validate_handle_grant_request_payload" },
              { "$ref": "#/$defs/validate_handle_grant_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "storage_file" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/storage_file_request_payload" },
              { "$ref": "#/$defs/storage_file_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "storage_kv" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/storage_kv_request_payload" },
              { "$ref": "#/$defs/storage_kv_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "storage_sqlite" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/storage_sqlite_request_payload" },
              { "$ref": "#/$defs/storage_sqlite_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "network_grant" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/network_grant_request_payload" },
              { "$ref": "#/$defs/network_grant_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "network_execute" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "oneOf": [
              { "$ref": "#/$defs/network_execute_request_payload" },
              { "$ref": "#/$defs/network_execute_response_payload" }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "revoke_epoch" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["plugin_instance_id", "revoke_epoch"],
            "properties": {
              "plugin_instance_id": { "type": "string", "minLength": 1 },
              "revoke_epoch": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "revoke_epoch_ack" } }, "required": ["frame_type"] },
      "then": {
        "required": ["runtime_generation_id", "payload"],
        "properties": {
          "payload": { "$ref": "#/$defs/revoke_epoch_ack_response_payload" }
        }
      }
    },
    {
      "if": { "properties": { "frame_type": { "const": "diagnostic" } }, "required": ["frame_type"] },
      "then": { "$ref": "#/$defs/runtime_response_frame" }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "worker_artifact_path": {
      "type": "string",
      "pattern": "^workers/(?!.*(?:^|/)\\.)(?!.*//)(?!.*\\\\).+\\.wasm$"
    },
    "heartbeat_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sent_unix_nano", "max_staleness_ms"],
      "properties": {
        "sent_unix_nano": { "type": "integer", "minimum": 1 },
        "max_staleness_ms": { "type": "integer", "minimum": 1 }
      }
    },
    "heartbeat_response_payload": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "result"],
          "properties": {
            "ok": { "const": true },
            "result": { "$ref": "#/$defs/heartbeat_ack_result" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "code", "message", "error_origin"],
          "properties": {
            "ok": { "const": false },
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 },
            "error_origin": { "enum": ["runtime", "hostcall", "plugin"] }
          }
        }
      ]
    },
    "heartbeat_ack_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_generation_id",
        "runtime_unix_nano",
        "max_staleness_ms",
        "host_sent_unix_nano"
      ],
      "properties": {
        "runtime_generation_id": { "type": "string", "minLength": 1 },
        "runtime_unix_nano": { "type": "integer", "minimum": 1 },
        "max_staleness_ms": { "type": "integer", "minimum": 1 },
        "host_sent_unix_nano": { "type": "integer", "minimum": 1 }
      }
    },
    "hostcall_failure_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "code", "message", "error_origin"],
      "properties": {
        "ok": { "const": false },
        "code": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Z][A-Z0-9_]{0,127}$" },
        "message": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "error_origin": { "const": "hostcall" }
      }
    },
    "open_handle_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package_hash", "artifact", "artifact_sha256"],
      "properties": {
        "package_hash": { "$ref": "#/$defs/sha256" },
        "artifact": { "$ref": "#/$defs/worker_artifact_path" },
        "artifact_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "open_handle_response_payload": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "package_hash", "artifact", "sha256", "content_base64"],
          "properties": {
            "ok": { "const": true },
            "package_hash": { "$ref": "#/$defs/sha256" },
            "artifact": { "$ref": "#/$defs/worker_artifact_path" },
            "sha256": { "$ref": "#/$defs/sha256" },
            "content_base64": { "type": "string", "contentEncoding": "base64" }
          }
        },
        { "$ref": "#/$defs/hostcall_failure_response_payload" }
      ]
    },
    "validate_handle_grant_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handle_grant_token",
        "plugin_instance_id",
        "active_fingerprint",
        "runtime_instance_id",
        "runtime_generation_id",
        "runtime_shard_id",
        "handle_id",
        "method",
        "policy_revision",
        "management_revision",
        "revoke_epoch"
      ],
      "properties": {
        "handle_grant_token": { "type": "string", "minLength": 1 },
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "active_fingerprint": { "type": "string", "minLength": 1 },
        "runtime_instance_id": { "type": "string", "minLength": 1 },
        "runtime_generation_id": { "type": "string", "minLength": 1 },
        "runtime_shard_id": { "type": "string", "minLength": 1 },
        "handle_id": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "policy_revision": { "type": "integer", "minimum": 0 },
        "management_revision": { "type": "integer", "minimum": 0 },
        "revoke_epoch": { "type": "integer", "minimum": 0 }
      }
    },
    "validate_handle_grant_response_payload": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "handle_grant_id", "handle_id", "method", "runtime_generation_id"],
          "properties": {
            "ok": { "const": true },
            "handle_grant_id": { "type": "string", "minLength": 1 },
            "handle_id": { "type": "string", "minLength": 1 },
            "method": { "type": "string", "minLength": 1 },
            "runtime_generation_id": { "type": "string", "minLength": 1 },
            "max_bytes_per_second": { "type": "integer", "minimum": 0 },
            "max_total_bytes": { "type": "integer", "minimum": 0 }
          }
        },
        { "$ref": "#/$defs/hostcall_failure_response_payload" }
      ]
    },
    "storage_file_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handle_grant_token",
        "plugin_instance_id",
        "active_fingerprint",
        "runtime_instance_id",
        "runtime_generation_id",
        "runtime_shard_id",
        "handle_id",
        "method",
        "policy_revision",
        "management_revision",
        "revoke_epoch",
        "operation",
        "store_id"
      ],
      "properties": {
        "handle_grant_token": { "type": "string", "minLength": 1 },
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "active_fingerprint": { "type": "string", "minLength": 1 },
        "runtime_instance_id": { "type": "string", "minLength": 1 },
        "runtime_generation_id": { "type": "string", "minLength": 1 },
        "runtime_shard_id": { "type": "string", "minLength": 1 },
        "handle_id": { "type": "string", "pattern": "^storage:[A-Za-z0-9_.-]+$" },
        "method": { "const": "storage.files" },
        "policy_revision": { "type": "integer", "minimum": 0 },
        "management_revision": { "type": "integer", "minimum": 0 },
        "revoke_epoch": { "type": "integer", "minimum": 0 },
        "operation": { "enum": ["read", "write", "delete", "list"] },
        "store_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
        "path": { "type": "string" },
        "data_base64": { "type": "string", "contentEncoding": "base64" },
        "max_bytes": { "type": "integer", "minimum": 0 },
        "max_entries": { "type": "integer", "minimum": 0 },
        "recursive": { "type": "boolean" }
      }
    },
    "storage_file_response_payload": {
      "oneOf": [
        { "$ref": "#/$defs/storage_file_read_success_response_payload" },
        { "$ref": "#/$defs/storage_file_write_success_response_payload" },
        { "$ref": "#/$defs/storage_file_delete_success_response_payload" },
        { "$ref": "#/$defs/storage_file_list_success_response_payload" },
        { "$ref": "#/$defs/hostcall_failure_response_payload" }
      ]
    },
    "storage_file_read_success_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "path", "data_base64", "size_bytes", "usage"],
      "properties": {
        "ok": { "const": true },
        "path": { "type": "string" },
        "data_base64": { "type": "string", "contentEncoding": "base64" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "usage": { "$ref": "#/$defs/storage_usage" }
      }
    },
    "storage_file_write_success_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "path", "size_bytes", "usage"],
      "properties": {
        "ok": { "const": true },
        "path": { "type": "string" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "usage": { "$ref": "#/$defs/storage_usage" }
      }
    },
    "storage_file_delete_success_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "path"],
      "properties": {
        "ok": { "const": true },
        "path": { "type": "string" }
      }
    },
    "storage_file_list_success_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "path", "entries", "usage"],
      "properties": {
        "ok": { "const": true },
        "path": { "type": "string" },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/storage_file_entry" }
        },
        "usage": { "$ref": "#/$defs/storage_usage" }
      }
    },
    "storage_file_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "dir", "updated_at"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "dir": { "type": "boolean" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "storage_kv_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handle_grant_token",
        "plugin_instance_id",
        "active_fingerprint",
        "runtime_instance_id",
        "runtime_generation_id",
        "runtime_shard_id",
        "handle_id",
        "method",
        "policy_revision",
        "management_revision",
        "revoke_epoch",
        "operation",
        "store_id"
      ],
      "properties": {
        "handle_grant_token": { "type": "string", "minLength": 1 },
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "active_fingerprint": { "type": "string", "minLength": 1 },
        "runtime_instance_id": { "type": "string", "minLength": 1 },
        "runtime_generation_id": { "type": "string", "minLength": 1 },
        "runtime_shard_id": { "type": "string", "minLength": 1 },
        "handle_id": { "type": "string", "pattern": "^storage:[A-Za-z0-9_.-]+$" },
        "method": { "const": "storage.kv" },
        "policy_revision": { "type": "integer", "minimum": 0 },
        "management_revision": { "type": "integer", "minimum": 0 },
        "revoke_epoch": { "type": "integer", "minimum": 0 },
        "operation": { "enum": ["get", "put", "delete", "list"] },
        "store_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
        "key": { "type": "string" },
        "value_base64": { "type": "string", "contentEncoding": "base64" },
        "prefix": { "type": "string" },
        "max_bytes": { "type": "integer", "minimum": 0 },
        "max_entries": { "type": "integer", "minimum": 0 }
      }
    },
    "storage_kv_response_payload": {
      "oneOf": [
        { "$ref": "#/$defs/storage_kv_get_success_response_payload" },
        { "$ref": "#/$defs/storage_kv_put_success_response_payload" },
        { "$ref": "#/$defs/storage_kv_delete_success_response_payload" },
        { "$ref": "#/$defs/storage_kv_list_success_response_payload" },
        { "$ref": "#/$defs/hostcall_failure_response_payload" }
      ]
    },
    "storage_kv_get_success_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "key", "value_base64", "size_bytes", "usage"],
      "properties": {
        "ok": { "const": true },
        "key": { "type": "string" },
        "value_base64": { "type": "string", "contentEncoding": "base64" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "usage": { "$ref": "#/$defs/storage_usage" }
      }
    },
    "storage_kv_put_success_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "key", "size_bytes", "usage"],
      "properties": {
        "ok": { "const": true },
        "key": { "type": "string" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "usage": { "$ref": "#/$defs/storage_usage" }
      }
    },
    "storage_kv_delete_success_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "key"],
      "properties": {
        "ok": { "const": true },
        "key": { "type": "string" }
      }
    },
    "storage_kv_list_success_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "entries", "usage"],
      "properties": {
        "ok": { "const": true },
        "prefix": { "type": "string" },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/storage_kv_entry" }
        },
        "usage": { "$ref": "#/$defs/storage_usage" }
      }
    },
    "storage_kv_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "size_bytes", "updated_at"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "storage_sqlite_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handle_grant_token",
        "plugin_instance_id",
        "active_fingerprint",
        "runtime_instance_id",
        "runtime_generation_id",
        "runtime_shard_id",
        "handle_id",
        "method",
        "policy_revision",
        "management_revision",
        "revoke_epoch",
        "operation",
        "store_id",
        "sql"
      ],
      "properties": {
        "handle_grant_token": { "type": "string", "minLength": 1 },
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "active_fingerprint": { "type": "string", "minLength": 1 },
        "runtime_instance_id": { "type": "string", "minLength": 1 },
        "runtime_generation_id": { "type": "string", "minLength": 1 },
        "runtime_shard_id": { "type": "string", "minLength": 1 },
        "handle_id": { "type": "string", "pattern": "^storage:[A-Za-z0-9_.-]+$" },
        "method": { "const": "storage.sqlite" },
        "policy_revision": { "type": "integer", "minimum": 0 },
        "management_revision": { "type": "integer", "minimum": 0 },
        "revoke_epoch": { "type": "integer", "minimum": 0 },
        "operation": { "enum": ["exec", "query"] },
        "store_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
        "database": { "type": "string" },
        "sql": { "type": "string", "minLength": 1 },
        "args": {
          "type": "array",
          "items": { "$ref": "#/$defs/storage_sqlite_value" }
        },
        "max_rows": { "type": "integer", "minimum": 0 },
        "max_response_bytes": { "type": "integer", "minimum": 0 },
        "timeout_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "storage_sqlite_response_payload": {
      "oneOf": [
        { "$ref": "#/$defs/storage_sqlite_exec_success_response_payload" },
        { "$ref": "#/$defs/storage_sqlite_query_success_response_payload" },
        { "$ref": "#/$defs/hostcall_failure_response_payload" }
      ]
    },
    "storage_sqlite_exec_success_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "database", "rows_affected", "usage"],
      "properties": {
        "ok": { "const": true },
        "database": { "type": "string" },
        "rows_affected": { "type": "integer", "minimum": 0 },
        "last_insert_id": { "type": "integer", "minimum": 0 },
        "usage": { "$ref": "#/$defs/storage_usage" }
      }
    },
    "storage_sqlite_query_success_response_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "database", "columns", "rows", "usage"],
      "properties": {
        "ok": { "const": true },
        "database": { "type": "string" },
        "columns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "$ref": "#/$defs/storage_sqlite_value" }
          }
        },
        "usage": { "$ref": "#/$defs/storage_usage" }
      }
    },
    "storage_sqlite_value": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        { "required": ["null"], "properties": { "null": { "const": true } } },
        { "required": ["int"] },
        { "required": ["float"] },
        { "required": ["text"] },
        { "required": ["blob_base64"] }
      ],
      "properties": {
        "null": { "type": "boolean" },
        "int": { "type": "integer" },
        "float": { "type": "number" },
        "text": { "type": "string" },
        "blob_base64": { "type": "string", "contentEncoding": "base64" }
      }
    },
    "storage_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plugin_instance_id", "store_id", "usage_bytes", "quota_bytes", "usage_files", "quota_files"],
      "properties": {
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "store_id": { "type": "string", "minLength": 1 },
        "usage_bytes": { "type": "integer", "minimum": 0 },
        "quota_bytes": { "type": "integer", "minimum": 0 },
        "usage_files": { "type": "integer", "minimum": 0 },
        "quota_files": { "type": "integer", "minimum": 0 }
      }
    },
    "network_grant_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_instance_id",
        "active_fingerprint",
        "runtime_instance_id",
        "runtime_generation_id",
        "runtime_shard_id",
        "policy_revision",
        "management_revision",
        "revoke_epoch",
        "connector_id",
        "transport",
        "destination"
      ],
      "properties": {
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "active_fingerprint": { "type": "string", "minLength": 1 },
        "runtime_instance_id": { "type": "string", "minLength": 1 },
        "runtime_generation_id": { "type": "string", "minLength": 1 },
        "runtime_shard_id": { "type": "string", "minLength": 1 },
        "policy_revision": { "type": "integer", "minimum": 0 },
        "management_revision": { "type": "integer", "minimum": 0 },
        "revoke_epoch": { "type": "integer", "minimum": 0 },
        "connector_id": { "type": "string", "minLength": 1 },
        "transport": { "enum": ["http", "websocket", "tcp", "udp"] },
        "destination": { "type": "string", "minLength": 1 },
        "ttl_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "network_grant_response_payload": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ok", "grant_id", "plugin_instance_id", "active_fingerprint",
            "policy_revision", "management_revision", "revoke_epoch", "connector_id",
            "transport", "destination", "runtime_generation_id",
            "target_classifier_version", "expires_at"
          ],
          "properties": {
            "ok": { "const": true },
            "grant_id": { "type": "string", "pattern": "^netgrant_[0-9a-f]{32}$" },
            "plugin_instance_id": { "type": "string", "minLength": 1 },
            "active_fingerprint": { "type": "string", "minLength": 1 },
            "policy_revision": { "type": "integer", "minimum": 0 },
            "management_revision": { "type": "integer", "minimum": 0 },
            "revoke_epoch": { "type": "integer", "minimum": 0 },
            "connector_id": { "type": "string", "minLength": 1 },
            "transport": { "enum": ["http", "websocket", "tcp", "udp"] },
            "destination": { "$ref": "#/$defs/network_destination" },
            "runtime_generation_id": { "type": "string", "minLength": 1 },
            "target_classifier_version": { "const": "target-classifier-v2" },
            "expires_at": { "type": "string", "format": "date-time" }
          }
        },
        { "$ref": "#/$defs/hostcall_failure_response_payload" }
      ]
    },
    "network_execute_request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_id",
        "plugin_instance_id",
        "active_fingerprint",
        "runtime_instance_id",
        "runtime_generation_id",
        "runtime_shard_id",
        "policy_revision",
        "management_revision",
        "revoke_epoch",
        "connector_id",
        "transport",
        "destination",
        "owner_session_hash",
        "owner_user_hash",
        "owner_env_hash",
        "session_channel_id_hash"
      ],
      "properties": {
        "plugin_id": { "type": "string", "minLength": 1 },
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "active_fingerprint": { "type": "string", "minLength": 1 },
        "runtime_instance_id": { "type": "string", "minLength": 1 },
        "runtime_generation_id": { "type": "string", "minLength": 1 },
        "runtime_shard_id": { "type": "string", "minLength": 1 },
        "policy_revision": { "type": "integer", "minimum": 0 },
        "management_revision": { "type": "integer", "minimum": 0 },
        "revoke_epoch": { "type": "integer", "minimum": 0 },
        "connector_id": { "type": "string", "minLength": 1 },
        "transport": { "enum": ["http", "websocket", "tcp", "udp"] },
        "destination": { "type": "string", "minLength": 1 },
        "ttl_ms": { "type": "integer", "minimum": 0 },
        "operation": { "enum": ["http", "http_stream", "websocket_round_trip", "tcp_round_trip", "udp_round_trip"] },
        "method": { "type": "string", "minLength": 1 },
        "path": { "type": "string" },
        "query": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "message_type": { "enum": ["text", "binary"] },
        "body_base64": { "type": "string", "contentEncoding": "base64" },
        "payload_base64": { "type": "string", "contentEncoding": "base64" },
        "max_request_bytes": { "type": "integer", "minimum": 0 },
        "max_response_bytes": { "type": "integer", "minimum": 0 },
        "max_chunk_bytes": { "type": "integer", "minimum": 0 },
        "max_buffered_bytes": { "type": "integer", "minimum": 0 },
        "timeout_ms": { "type": "integer", "minimum": 0 },
        "stream_id": { "type": "string" },
        "stream_method": { "type": "string" },
        "stream_effect": { "enum": ["read", "write", "execute", "delete", "admin"] },
        "stream_execution": { "enum": ["sync", "operation", "subscription"] },
        "surface_instance_id": { "type": "string" },
        "owner_session_hash": { "type": "string" },
        "owner_user_hash": { "type": "string" },
        "owner_env_hash": { "type": "string", "minLength": 1 },
        "session_channel_id_hash": { "type": "string" },
        "bridge_channel_id": { "type": "string" },
        "content_type": { "type": "string" }
      }
    },
    "network_execute_response_payload": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "transport", "destination", "grant_id", "connector_id", "runtime_generation_id"],
          "properties": {
            "ok": { "const": true },
            "transport": { "enum": ["http", "websocket", "tcp", "udp"] },
            "destination": { "$ref": "#/$defs/network_destination" },
            "status_code": { "type": "integer", "minimum": 100, "maximum": 599 },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "message_type": { "enum": ["text", "binary"] },
            "body_base64": { "type": "string", "contentEncoding": "base64" },
            "payload_base64": { "type": "string", "contentEncoding": "base64" },
            "stream_id": { "type": "string", "minLength": 1 },
            "bytes_read": { "type": "integer", "minimum": 0 },
            "chunk_count": { "type": "integer", "minimum": 0 },
            "grant_id": { "type": "string", "pattern": "^netgrant_[0-9a-f]{32}$" },
            "connector_id": { "type": "string", "minLength": 1 },
            "runtime_generation_id": { "type": "string", "minLength": 1 }
          }
        },
        { "$ref": "#/$defs/hostcall_failure_response_payload" }
      ]
    },
    "network_destination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transport", "host", "port"],
      "properties": {
        "transport": { "enum": ["http", "websocket", "tcp", "udp"] },
        "scheme": { "enum": ["http", "https", "ws", "wss"] },
        "host": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "revoke_epoch_ack_response_payload": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "result"],
          "properties": {
            "ok": { "const": true },
            "result": { "$ref": "#/$defs/revoke_epoch_ack_result" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "code", "message", "error_origin"],
          "properties": {
            "ok": { "const": false },
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 },
            "error_origin": { "enum": ["runtime", "hostcall", "plugin"] }
          }
        }
      ]
    },
    "revoke_epoch_ack_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_instance_id",
        "revoke_epoch",
        "closed_socket_count",
        "closed_stream_count",
        "closed_storage_handle_count"
      ],
      "properties": {
        "plugin_instance_id": { "type": "string", "minLength": 1 },
        "revoke_epoch": { "type": "integer", "minimum": 0 },
        "closed_socket_count": { "type": "integer", "minimum": 0 },
        "closed_stream_count": { "type": "integer", "minimum": 0 },
        "closed_storage_handle_count": { "type": "integer", "minimum": 0 }
      }
    },
    "runtime_response_frame": {
      "required": ["runtime_generation_id", "payload"],
      "properties": {
        "payload": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["ok", "result"],
              "properties": {
                "ok": { "const": true },
                "result": true
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["ok", "code", "message", "error_origin"],
              "properties": {
                "ok": { "const": false },
                "code": { "type": "string", "minLength": 1 },
                "message": { "type": "string", "minLength": 1 },
                "error_origin": { "enum": ["runtime", "hostcall", "plugin"] }
              }
            }
          ]
        }
      }
    }
  }
}
