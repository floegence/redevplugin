{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/compatibility-manifest-v1.schema.json",
  "title": "ReDevPlugin compatibility manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "matrix", "contracts"],
  "properties": {
    "schema_version": { "const": "redevplugin.compatibility.v1" },
    "matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redevplugin_go_version",
        "redevplugin_ui_version",
        "redevplugin_runtime_version",
        "plugin_host_protocol_version",
        "rust_ipc_version",
        "wasm_abi_version",
        "manifest_schema_version",
        "package_signature_schema_version",
        "token_ticket_schema_version",
        "bridge_schema_version",
        "target_classifier_version",
        "plugin_platform_openapi_version",
        "compatibility_schema_version"
      ],
      "properties": {
        "redevplugin_go_version": { "type": "string", "minLength": 1 },
        "redevplugin_ui_version": { "type": "string", "minLength": 1 },
        "redevplugin_runtime_version": { "type": "string", "minLength": 1 },
        "plugin_host_protocol_version": { "const": "plugin-host-v1" },
        "rust_ipc_version": { "const": "rust-ipc-v1" },
        "wasm_abi_version": { "const": "redeven-wasm-worker-v1" },
        "manifest_schema_version": { "const": "manifest-v1" },
        "package_signature_schema_version": { "const": "package-signature-v1" },
        "token_ticket_schema_version": { "const": "token-ticket-v1" },
        "bridge_schema_version": { "const": "bridge-v1" },
        "target_classifier_version": { "const": "target-classifier-v1" },
        "plugin_platform_openapi_version": { "const": "plugin-platform-v1" },
        "compatibility_schema_version": { "const": "compatibility-manifest-v1" }
      }
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/contract" }
    }
  },
  "$defs": {
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "version", "sha256"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": {
          "type": "string",
          "pattern": "^(spec/openapi|spec/plugin)/[A-Za-z0-9._/-]+$"
        },
        "version": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
