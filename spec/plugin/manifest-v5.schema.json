{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/manifest-v5.schema.json",
  "title": "ReDevPlugin manifest v5",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "publisher", "plugin", "surfaces"],
  "properties": {
    "schema_version": { "const": "redevplugin.manifest.v5" },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publisher_id"],
      "properties": {
        "publisher_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string" }
      }
    },
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plugin_id", "display_name", "version", "api_version", "min_runtime_version", "ui_protocol_version"],
      "properties": {
        "plugin_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "api_version": { "const": "plugin-v1" },
        "min_runtime_version": { "type": "string", "minLength": 1 },
        "ui_protocol_version": { "const": "plugin-ui-v5" }
      }
    },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["surface_id", "kind", "label", "entry"],
        "properties": {
          "surface_id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["view", "command", "background"] },
          "intent": { "enum": ["primary", "secondary", "utility"] },
          "label": { "type": "string", "minLength": 1 },
          "entry": { "type": "string", "minLength": 1 },
          "icon": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_][A-Za-z0-9_.-]*(?:/[A-Za-z0-9_][A-Za-z0-9_.-]*)*\\.(?:[Pp][Nn][Gg]|[Jj][Pp][Gg]|[Jj][Pp][Ee][Gg]|[Gg][Ii][Ff]|[Ww][Ee][Bb][Pp]|[Ii][Cc][Oo])$"
          },
          "default_size": {
            "type": "object",
            "additionalProperties": false,
            "required": ["width", "height"],
            "properties": {
              "width": { "type": "integer", "minimum": 1 },
              "height": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "capability_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["binding_id", "contract"],
        "properties": {
          "binding_id": { "type": "string", "minLength": 1 },
          "contract": { "$ref": "host-capability-pin-v1.schema.json" }
        }
      }
    },
    "methods": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["method", "route"],
        "properties": {
          "method": { "type": "string", "minLength": 1 },
          "effect": { "enum": ["read", "write", "delete", "execute", "admin"] },
          "execution": { "enum": ["sync", "operation", "subscription"] },
          "dangerous": { "type": "boolean" },
          "preflight_only": { "type": "boolean" },
          "broker_access": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "storage": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["store_id", "operations"],
                  "properties": {
                    "store_id": { "type": "string", "minLength": 1, "maxLength": 128 },
                    "operations": {
                      "type": "array",
                      "minItems": 1,
                      "uniqueItems": true,
                      "items": { "enum": ["read", "write", "delete", "list", "get", "put", "query", "exec"] }
                    }
                  }
                }
              },
              "network": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["connector_id", "transport", "operations"],
                  "properties": {
                    "connector_id": { "type": "string", "minLength": 1, "maxLength": 128 },
                    "transport": { "enum": ["http", "websocket", "tcp", "udp"] },
                    "operations": {
                      "type": "array",
                      "minItems": 1,
                      "uniqueItems": true,
                      "items": { "enum": ["http", "http_stream", "websocket_round_trip", "tcp_round_trip", "udp_round_trip"] }
                    },
                    "http_methods": {
                      "type": "array",
                      "minItems": 1,
                      "uniqueItems": true,
                      "items": { "enum": ["GET", "HEAD", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"] }
                    }
                  },
                  "allOf": [
                    {
                      "if": { "properties": { "transport": { "const": "http" } }, "required": ["transport"] },
                      "then": { "required": ["http_methods"] },
                      "else": { "not": { "required": ["http_methods"] } }
                    }
                  ]
                }
              }
            }
          },
          "route": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind"],
            "properties": {
              "kind": { "enum": ["capability", "worker", "core_action"] },
              "binding_id": { "type": "string", "minLength": 1 },
              "target_method": { "type": "string", "minLength": 1 },
              "worker_id": { "type": "string", "minLength": 1 },
              "export": { "type": "string", "minLength": 1 },
              "action_id": { "type": "string", "minLength": 1 }
            },
            "allOf": [
              {
                "if": { "properties": { "kind": { "const": "capability" } }, "required": ["kind"] },
                "then": {
                  "required": ["binding_id", "target_method"],
                  "not": {
                    "anyOf": [
                      { "required": ["worker_id"] },
                      { "required": ["export"] },
                      { "required": ["action_id"] }
                    ]
                  }
                }
              },
              {
                "if": { "properties": { "kind": { "const": "worker" } }, "required": ["kind"] },
                "then": {
                  "required": ["worker_id", "export"],
                  "not": {
                    "anyOf": [
                      { "required": ["binding_id"] },
                      { "required": ["target_method"] },
                      { "required": ["action_id"] }
                    ]
                  }
                }
              },
              {
                "if": { "properties": { "kind": { "const": "core_action" } }, "required": ["kind"] },
                "then": {
                  "required": ["action_id"],
                  "not": {
                    "anyOf": [
                      { "required": ["binding_id"] },
                      { "required": ["target_method"] },
                      { "required": ["worker_id"] },
                      { "required": ["export"] }
                    ]
                  }
                }
              }
            ]
          },
          "confirmation": {
            "type": "object",
            "additionalProperties": false,
            "required": ["mode"],
            "properties": {
              "mode": { "enum": ["none", "required", "risk_based"] },
              "preflight_method": { "type": ["string", "null"] },
              "request_hash_fields": { "type": "array", "items": { "type": "string" } },
              "plan_hash_required": { "type": "boolean" }
            }
          },
          "cancel_policy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["cancelable"],
            "properties": {
              "cancelable": { "type": "boolean" },
              "disable_behavior": { "enum": ["cancel", "orphan", "wait"] },
              "uninstall_behavior": { "enum": ["cancel_then_block_delete", "force_cleanup_allowed"] },
              "ack_timeout_ms": { "type": "integer", "minimum": 0 }
            },
            "allOf": [
              {
                "if": { "properties": { "cancelable": { "const": true } }, "required": ["cancelable"] },
                "then": {
                  "required": ["ack_timeout_ms"],
                  "properties": { "ack_timeout_ms": { "type": "integer", "minimum": 1 } }
                }
              },
              {
                "if": { "properties": { "cancelable": { "const": false } }, "required": ["cancelable"] },
                "then": {
                  "properties": { "ack_timeout_ms": { "const": 0 } }
                }
              }
            ]
          },
          "request_schema": {
            "allOf": [
              { "$ref": "#/$defs/method_schema" },
              {
                "type": "object",
                "required": ["type", "additionalProperties"],
                "properties": {
                  "type": { "const": "object" },
                  "additionalProperties": { "const": false }
                }
              }
            ]
          },
          "response_schema": {
            "allOf": [
              { "$ref": "#/$defs/method_schema" },
              {
                "type": "object",
                "required": ["type", "additionalProperties"],
                "properties": {
                  "type": { "const": "object" },
                  "additionalProperties": { "const": false }
                }
              }
            ]
          }
        },
        "allOf": [
          {
            "if": { "properties": { "dangerous": { "const": true } }, "required": ["dangerous"] },
            "then": {
              "required": ["confirmation"],
              "properties": {
                "confirmation": {
                  "properties": {
                    "mode": { "enum": ["required", "risk_based"] }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "route": {
                  "properties": { "kind": { "const": "capability" } },
                  "required": ["kind"]
                }
              },
              "required": ["route"]
            },
            "then": {
              "not": {
                "anyOf": [
                  { "required": ["effect"] },
                  { "required": ["execution"] },
                  { "required": ["dangerous"] },
                  { "required": ["preflight_only"] },
                  { "required": ["confirmation"] },
                  { "required": ["cancel_policy"] },
                  { "required": ["request_schema"] },
                  { "required": ["response_schema"] },
                  { "required": ["broker_access"] }
                ]
              }
            },
            "else": {
              "required": ["effect", "execution", "request_schema", "response_schema"]
            }
          },
          {
            "if": { "properties": { "preflight_only": { "const": true } }, "required": ["preflight_only"] },
            "then": {
              "properties": {
                "effect": { "const": "read" },
                "execution": { "const": "sync" },
                "dangerous": { "const": false }
              }
            }
          },
          {
            "if": { "properties": { "execution": { "enum": ["operation", "subscription"] } }, "required": ["execution"] },
            "then": { "required": ["cancel_policy"] }
          }
        ]
      }
    },
    "workers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["worker_id", "artifact", "abi", "mode", "scope", "memory_limit_bytes"],
        "properties": {
          "worker_id": { "type": "string", "minLength": 1 },
          "artifact": { "type": "string", "minLength": 1 },
          "abi": { "const": "redevplugin-wasm-worker-v2" },
          "mode": { "const": "job" },
          "scope": { "enum": ["user", "environment"] },
          "memory_limit_bytes": { "type": "integer", "minimum": 1, "maximum": 268435456 },
          "idle_timeout_ms": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stores": {
          "type": "array",
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["store_id", "kind", "scope", "quota_bytes", "schema_version", "migration"],
            "properties": {
              "store_id": { "type": "string", "minLength": 1 },
              "kind": { "enum": ["kv", "files", "sqlite"] },
              "scope": { "enum": ["user", "environment"] },
              "quota_bytes": { "type": "integer", "minimum": 1, "maximum": 1073741824 },
              "quota_files": { "type": "integer", "minimum": 1, "maximum": 100000 },
              "schema_version": { "type": "integer", "minimum": 1 },
              "migration": { "$ref": "#/$defs/migration" }
            }
          }
        }
      }
    },
    "network_access": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "connectors": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["connector_id", "transport", "scope", "destinations"],
            "properties": {
              "connector_id": { "type": "string", "minLength": 1 },
              "transport": { "enum": ["http", "websocket", "tcp", "udp"] },
              "scope": { "enum": ["user", "environment"] },
              "destinations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "auth": { "type": "object" },
              "tls": { "type": "object" }
            }
          }
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "migration"],
      "properties": {
        "schema_version": { "type": "integer", "minimum": 1 },
        "migration": { "$ref": "#/$defs/migration" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "type", "scope", "label"],
            "properties": {
              "key": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "minLength": 1 },
              "scope": { "enum": ["user", "environment"] },
              "label": { "type": "string", "minLength": 1 },
              "default": true,
              "secret_ref": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "validation": { "type": "object" }
            }
          }
        }
      }
    },
    "intents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["intent_id", "method"],
        "properties": {
          "intent_id": { "type": "string", "minLength": 1 },
          "method": { "type": "string", "minLength": 1 },
          "payload_schema": { "type": "object" }
        }
      }
    }
  },
  "$defs": {
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_version", "to_version", "reversible", "requires_worker", "estimated_bytes", "max_duration_ms", "data_loss_risk", "steps_hash"],
      "properties": {
        "from_version": { "type": "integer", "minimum": 0 },
        "to_version": { "type": "integer", "minimum": 1 },
        "reversible": { "type": "boolean" },
        "requires_worker": { "type": "boolean" },
        "estimated_bytes": { "type": "integer", "minimum": 0 },
        "max_duration_ms": { "type": "integer", "minimum": 0 },
        "data_loss_risk": { "type": "boolean" },
        "steps_hash": { "type": "string", "minLength": 1 }
      }
    },
    "method_schema": {
      "oneOf": [
        { "const": false },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "$comment": { "type": "string" },
            "title": { "type": "string" },
            "description": { "type": "string" },
            "deprecated": { "type": "boolean" },
            "readOnly": { "type": "boolean" },
            "writeOnly": { "type": "boolean" },
            "$ref": { "type": "string", "pattern": "^#/\\$defs/[A-Za-z0-9._-]+$" },
            "$defs": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/method_schema" }
            },
            "type": {
              "oneOf": [
                { "enum": ["null", "boolean", "object", "array", "number", "integer", "string"] },
                {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": { "enum": ["null", "boolean", "object", "array", "number", "integer", "string"] }
                }
              ]
            },
            "properties": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/method_schema" }
            },
            "patternProperties": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/method_schema" }
            },
            "required": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string" }
            },
            "additionalProperties": { "const": false },
            "items": { "$ref": "#/$defs/method_schema" },
            "allOf": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/method_schema" }
            },
            "anyOf": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/method_schema" }
            },
            "oneOf": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/method_schema" }
            },
            "enum": { "type": "array", "minItems": 1, "uniqueItems": true },
            "const": true,
            "default": true,
            "examples": { "type": "array" },
            "minimum": { "type": "number" },
            "maximum": { "type": "number" },
            "exclusiveMinimum": { "type": "number" },
            "exclusiveMaximum": { "type": "number" },
            "multipleOf": { "type": "number", "exclusiveMinimum": 0 },
            "minLength": { "type": "integer", "minimum": 0 },
            "maxLength": { "type": "integer", "minimum": 0 },
            "pattern": { "type": "string" },
            "format": { "type": "string" },
            "minItems": { "type": "integer", "minimum": 0 },
            "maxItems": { "type": "integer", "minimum": 0 },
            "uniqueItems": { "type": "boolean" },
            "minProperties": { "type": "integer", "minimum": 0 },
            "maxProperties": { "type": "integer", "minimum": 0 }
          },
          "anyOf": [
            { "required": ["type"] },
            { "required": ["$ref"] },
            { "required": ["properties"] },
            { "required": ["patternProperties"] },
            { "required": ["required"] },
            { "required": ["additionalProperties"] },
            { "required": ["minProperties"] },
            { "required": ["maxProperties"] },
            { "required": ["allOf"] },
            { "required": ["anyOf"] },
            { "required": ["oneOf"] },
            { "required": ["enum"] },
            { "required": ["const"] }
          ],
          "allOf": [
            {
              "if": {
                "required": ["type"],
                "properties": {
                  "type": {
                    "anyOf": [
                      { "const": "object" },
                      { "type": "array", "contains": { "const": "object" } }
                    ]
                  }
                }
              },
              "then": {
                "required": ["additionalProperties"],
                "properties": { "additionalProperties": { "const": false } }
              }
            },
            {
              "if": {
                "anyOf": [
                  { "required": ["properties"] },
                  { "required": ["patternProperties"] },
                  { "required": ["required"] },
                  { "required": ["additionalProperties"] },
                  { "required": ["minProperties"] },
                  { "required": ["maxProperties"] }
                ]
              },
              "then": {
                "required": ["additionalProperties"],
                "properties": { "additionalProperties": { "const": false } }
              }
            }
          ]
        }
      ]
    }
  }
}
