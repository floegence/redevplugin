{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/wasm-worker-v1.schema.json",
  "title": "ReDevPlugin WASM worker ABI v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["abi_version", "exports", "imports"],
  "properties": {
    "abi_version": { "const": "redevplugin-wasm-worker-v1" },
    "exports": {
      "type": "array",
      "items": { "enum": ["redevplugin_worker_invoke", "redevplugin_actor_start", "redevplugin_actor_stop"] },
      "uniqueItems": true
    },
    "imports": {
      "type": "array",
      "items": { "enum": ["redevplugin.log", "redevplugin.storage", "redevplugin.network", "redevplugin.operation", "redevplugin.clock"] },
      "uniqueItems": true
    }
  }
}

