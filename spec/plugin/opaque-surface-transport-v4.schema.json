{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/opaque-surface-transport-v4.schema.json",
  "title": "ReDevPlugin private opaque surface transport v4",
  "description": "Private messages between the trusted parent, trusted renderer, and isolated plugin worker. MessagePort transfer is represented by the envelope; transferable ports are not JSON values.",
  "oneOf": [
    { "$ref": "#/$defs/port_envelope" },
    { "$ref": "#/$defs/port_ack" },
    { "$ref": "#/$defs/initialize" },
    { "$ref": "#/$defs/first_paint" },
    { "$ref": "#/$defs/first_commit" },
    { "$ref": "#/$defs/worker_ready" },
    { "$ref": "#/$defs/surface_error" },
    { "$ref": "#/$defs/interaction" },
    { "$ref": "#/$defs/asset_read" },
    { "$ref": "#/$defs/asset_response" },
    { "$ref": "#/$defs/worker_initialize" }
  ],
  "$defs": {
    "opaque_handle": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]{7,159}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "port_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "frame_generation_id", "ui_protocol_version"],
      "properties": {
        "type": { "const": "redevplugin.surface.port" },
        "frame_generation_id": { "$ref": "#/$defs/opaque_handle" },
        "ui_protocol_version": { "const": "plugin-ui-v5" }
      }
    },
    "port_ack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "frame_generation_id"],
      "properties": {
        "type": { "const": "redevplugin.surface.port_ack" },
        "frame_generation_id": { "$ref": "#/$defs/opaque_handle" }
      }
    },
    "initialize": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "frame_generation_id", "surface_handle", "document"],
      "properties": {
        "type": { "const": "redevplugin.surface.initialize" },
        "frame_generation_id": { "$ref": "#/$defs/opaque_handle" },
        "surface_handle": { "$ref": "#/$defs/opaque_handle" },
        "document": {
          "$ref": "https://schemas.redevplugin.dev/plugin/opaque-surface-document-v3.schema.json"
        }
      }
    },
    "first_paint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": { "type": { "const": "redevplugin.surface.first_paint" } }
    },
    "first_commit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": { "type": { "const": "redevplugin.surface.first_commit" } }
    },
    "worker_ready": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": { "type": { "const": "redevplugin.surface.worker_ready" } }
    },
    "surface_error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "error"],
      "properties": {
        "type": { "const": "redevplugin.surface.error" },
        "error": { "type": "string", "maxLength": 512 }
      }
    },
    "interaction": {
      "description": "Port-bound host UI ownership observation. action and target_key are plugin-controlled semantic metadata and MUST NOT be used for permission, route authorization, or privilege decisions.",
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "frame_generation_id", "surface_handle", "sequence", "kind", "target_key", "action", "local_scroll", "selection_active"],
      "properties": {
        "type": { "const": "redevplugin.surface.interaction" },
        "frame_generation_id": { "$ref": "#/$defs/opaque_handle" },
        "surface_handle": { "$ref": "#/$defs/opaque_handle" },
        "sequence": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "kind": { "type": "string", "enum": ["activation", "focus", "wheel", "text-selection", "action"] },
        "target_key": { "type": ["string", "null"], "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
        "action": { "type": ["string", "null"], "pattern": "^[-A-Za-z0-9._:]{1,128}$" },
        "local_scroll": { "type": "boolean" },
        "selection_active": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "action" } }, "required": ["kind"] },
          "then": { "properties": { "action": { "type": "string" } } },
          "else": { "properties": { "action": { "const": null } } }
        },
        {
          "if": { "properties": { "kind": { "const": "wheel" } }, "required": ["kind"] },
          "else": { "properties": { "local_scroll": { "const": false } } }
        },
        {
          "if": { "properties": { "kind": { "const": "text-selection" } }, "required": ["kind"] },
          "else": { "properties": { "selection_active": { "const": false } } }
        }
      ]
    },
    "asset_read": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "request_id", "binding_id", "path", "sha256"],
      "properties": {
        "type": { "const": "redevplugin.surface.asset.read" },
        "request_id": { "$ref": "#/$defs/opaque_handle" },
        "binding_id": { "$ref": "#/$defs/opaque_handle" },
        "path": { "type": "string", "minLength": 1, "maxLength": 512 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "asset_response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "request_id", "binding_id", "ok", "path", "sha256", "content_type", "content_base64"],
      "properties": {
        "type": { "const": "redevplugin.surface.asset.response" },
        "request_id": { "$ref": "#/$defs/opaque_handle" },
        "binding_id": { "$ref": "#/$defs/opaque_handle" },
        "ok": { "const": true },
        "path": { "type": "string", "minLength": 1, "maxLength": 512 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "content_type": { "type": "string", "minLength": 1, "maxLength": 256 },
        "content_base64": { "type": "string", "contentEncoding": "base64" }
      }
    },
    "worker_initialize": {
      "description": "Transferred ports are ordered as runtime_control then plugin_bridge; only plugin_bridge is exposed through the worker SDK claim.",
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "surface_handle", "ui_protocol_version", "port_roles"],
      "properties": {
        "type": { "const": "redevplugin.worker.initialize" },
        "surface_handle": { "$ref": "#/$defs/opaque_handle" },
        "ui_protocol_version": { "const": "plugin-ui-v5" },
        "port_roles": {
          "type": "array",
          "prefixItems": [
            { "const": "runtime_control" },
            { "const": "plugin_bridge" }
          ],
          "minItems": 2,
          "maxItems": 2
        }
      }
    }
  }
}
