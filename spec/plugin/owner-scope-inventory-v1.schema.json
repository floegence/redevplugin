{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/owner-scope-inventory-v1.schema.json",
  "title": "ReDevPlugin owner scope inventory registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "inventories"],
  "properties": {
    "schema_version": { "const": "owner-scope-inventory-v1" },
    "inventories": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "$ref": "#/$defs/inventory" }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "identifier": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$" },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^[a-z][a-z0-9._-]*(?:/[a-z][a-z0-9._-]*)*$"
    },
    "inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "platform_versions", "root_entries", "sqlite_databases", "tree_rules"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "platform_versions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^0\\.[1-6]\\.[0-9]+$" }
        },
        "root_entries": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "kind", "scope", "disposition", "required"],
            "properties": {
              "path": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$" },
              "kind": { "const": "directory" },
              "scope": { "const": "durable" },
              "disposition": { "const": "quarantine" },
              "required": { "type": "boolean" }
            }
          }
        },
        "sqlite_databases": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/sqlite_database" }
        },
        "tree_rules": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowed_kinds", "allow_sqlite_wal_shm", "reject_hardlinks", "reject_symlinks", "variable_trees", "optional_files"],
          "properties": {
            "allowed_kinds": { "const": ["directory", "file"] },
            "allow_sqlite_wal_shm": { "const": true },
            "reject_hardlinks": { "const": true },
            "reject_symlinks": { "const": true },
            "variable_trees": {
              "type": "array",
              "maxItems": 15,
              "uniqueItems": true,
              "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$" }
            },
            "optional_files": {
              "type": "array",
              "maxItems": 16,
              "uniqueItems": true,
              "items": { "type": "string", "pattern": "^db/[a-z][a-z0-9_]*\\.json$" }
            }
          }
        }
      }
    },
    "sqlite_database": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "required",
        "application_id",
        "user_version",
        "migration_versions",
        "schema_objects",
        "schema_sha256"
      ],
      "properties": {
        "path": { "$ref": "#/$defs/relative_path" },
        "required": { "type": "boolean" },
        "application_id": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "user_version": { "type": "integer", "minimum": 0, "maximum": 2147483647 },
        "migration_versions": {
          "type": "array",
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["table", "versions"],
            "properties": {
              "table": { "$ref": "#/$defs/identifier" },
              "versions": {
                "type": "array",
                "minItems": 1,
                "maxItems": 64,
                "uniqueItems": true,
                "items": { "type": "integer", "minimum": 0, "maximum": 2147483647 }
              }
            }
          }
        },
        "schema_objects": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "name", "table_name", "sql"],
            "properties": {
              "type": { "enum": ["index", "table"] },
              "name": { "$ref": "#/$defs/identifier" },
              "table_name": { "$ref": "#/$defs/identifier" },
              "sql": { "type": "string", "minLength": 1, "maxLength": 16384 }
            }
          }
        },
        "schema_sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
