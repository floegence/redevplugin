{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/release-signing-ledger-receipt-v1.schema.json",
  "title": "ReDevPlugin release signing ledger receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "log_id", "source_id", "subject_identity_sha256", "signing_preimage_sha256",
    "signature_envelope_sha256", "sequence", "leaf_index", "tree_size", "log_root_hash",
    "latest_map_root_hash", "checkpoint_sha256", "checkpoint_time", "key_id", "signature"
  ],
  "properties": {
    "schema_version": { "const": "redevplugin.release_signing_ledger_receipt.v1" },
    "log_id": { "$ref": "#/$defs/id" },
    "source_id": { "$ref": "#/$defs/id" },
    "channel": { "$ref": "#/$defs/id" },
    "subject_identity_sha256": { "$ref": "#/$defs/sha256" },
    "signing_preimage_sha256": { "$ref": "#/$defs/sha256" },
    "signature_envelope_sha256": { "$ref": "#/$defs/sha256" },
    "sequence": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "leaf_index": { "type": "integer", "minimum": 0, "maximum": 9007199254740990 },
    "tree_size": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "log_root_hash": { "$ref": "#/$defs/sha256" },
    "latest_map_root_hash": { "$ref": "#/$defs/sha256" },
    "checkpoint_sha256": { "$ref": "#/$defs/sha256" },
    "checkpoint_time": { "$ref": "#/$defs/time" },
    "key_id": { "$ref": "#/$defs/id" },
    "signature": { "type": "string", "pattern": "^[A-Za-z0-9+/]{86}==$" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "time": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" }
  }
}
