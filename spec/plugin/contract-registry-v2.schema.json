{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/contract-registry-v2.schema.json",
  "title": "ReDevPlugin Contract Registry V2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_version", "artifacts"],
  "properties": {
    "schema_version": {"const": "redevplugin.contract_registry.v2"},
    "registry_version": {"const": "contract-registry-v2"},
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/artifact"}
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "version", "sha256"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9-]+$",
          "not": {"const": "contract-registry"}
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024,
          "pattern": "^spec/(openapi|plugin)/[A-Za-z0-9][A-Za-z0-9._-]*(/[A-Za-z0-9][A-Za-z0-9._-]*)*$",
          "not": {"enum": ["spec/plugin/contract-registry-v2.json", "spec/plugin/platform-package-set-v1.json"]}
        },
        "version": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
