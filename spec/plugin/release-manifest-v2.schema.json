{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/release-manifest-v2.schema.json",
  "title": "ReDevPlugin release manifest v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "version",
    "source_commit",
    "runtime_target",
    "generated_at",
    "compatibility_sha256",
    "npm_package",
    "files"
  ],
  "properties": {
    "schema_version": { "const": "redevplugin.release_manifest.v2" },
    "version": { "type": "string", "minLength": 1 },
    "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "runtime_target": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "compatibility_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "npm_package": { "$ref": "#/$defs/npm_package" },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/file" }
    }
  },
  "$defs": {
    "npm_package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "path", "sha256", "integrity", "size"],
      "properties": {
        "name": { "const": "@floegence/redevplugin-ui" },
        "version": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "pattern": "^npm/floegence-redevplugin-ui-[A-Za-z0-9._+-]+\\.tgz$" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "integrity": { "type": "string", "pattern": "^sha512-[A-Za-z0-9+/]+={0,2}$" },
        "size": { "type": "integer", "minimum": 1 }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._/@+-]+$",
          "not": {
            "anyOf": [
              { "pattern": "^/" },
              { "pattern": "(^|/)\\.\\.(/|$)" },
              { "pattern": "\\\\" }
            ]
          }
        },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "size": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
