{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/release-manifest-v1.schema.json",
  "title": "ReDevPlugin release manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "version", "runtime_target", "generated_at", "files"],
  "properties": {
    "schema_version": { "const": "redevplugin.release_manifest.v1" },
    "version": { "type": "string", "minLength": 1 },
    "runtime_target": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/file" }
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._/@+-]+$",
          "not": {
            "anyOf": [
              { "pattern": "^/" },
              { "pattern": "(^|/)\\.\\.(/|$)" },
              { "pattern": "\\\\" }
            ]
          }
        },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "size": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
