{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/manifest-v1.schema.json",
  "title": "ReDevPlugin manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["plugin_id", "publisher", "version", "display_name", "redeven", "ui", "backend"],
  "properties": {
    "plugin_id": { "type": "string", "minLength": 1 },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string" }
      }
    },
    "version": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "redeven": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api_version", "min_runtime_version"],
      "properties": {
        "api_version": { "const": "plugin-v1" },
        "min_runtime_version": { "type": "string", "minLength": 1 }
      }
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entrypoint", "sandbox"],
      "properties": {
        "entrypoint": { "type": "string", "minLength": 1 },
        "sandbox": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tokens"],
          "properties": {
            "tokens": {
              "type": "array",
              "items": { "const": "allow-scripts" },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["none", "wasm"] },
        "path": { "type": "string" }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["binding_id", "capability_id", "min_capability_version"],
        "properties": {
          "binding_id": { "type": "string", "minLength": 1 },
          "capability_id": { "type": "string", "minLength": 1 },
          "min_capability_version": { "type": "string", "minLength": 1 }
        }
      }
    },
    "methods": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "effect", "execution_mode", "route"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "effect": { "enum": ["read", "write", "execute", "delete", "admin"] },
          "execution_mode": { "enum": ["sync", "operation", "stream"] },
          "dangerous": { "type": "boolean" },
          "route": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind"],
            "properties": {
              "kind": { "enum": ["capability", "worker"] },
              "binding_id": { "type": "string" },
              "worker_func": { "type": "string" }
            }
          }
        }
      }
    },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["surface_id", "kind", "label"],
        "properties": {
          "surface_id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["activity", "workbench_widget", "settings_section"] },
          "label": { "type": "string", "minLength": 1 },
          "method": { "type": "string" }
        }
      }
    },
    "settings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "type", "label", "scope"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "scope": { "enum": ["user", "environment"] },
          "secret_ref": { "type": "string" },
          "options": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "intents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["intent_id", "method"],
        "properties": {
          "intent_id": { "type": "string", "minLength": 1 },
          "method": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}

