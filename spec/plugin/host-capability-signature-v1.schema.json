{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/host-capability-signature-v1.schema.json",
  "title": "ReDevPlugin host capability signature v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "algorithm", "key_id", "manifest_sha256", "signature_base64"],
  "properties": {
    "schema_version": { "const": "redevplugin.host_capability_signature.v1" },
    "algorithm": { "const": "ed25519" },
    "key_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
    "manifest_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "signature_base64": {
      "type": "string",
      "minLength": 88,
      "maxLength": 88,
      "pattern": "^[A-Za-z0-9+/]{86}==$",
      "contentEncoding": "base64"
    }
  }
}
