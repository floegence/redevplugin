{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/release-manifest-v4.schema.json",
  "title": "ReDevPlugin release manifest v4",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "version",
    "source_commit",
    "runtime_target",
    "generated_at",
    "compatibility_sha256",
    "npm_package",
    "worker_sdk",
    "files"
  ],
  "properties": {
    "schema_version": { "const": "redevplugin.release_manifest.v4" },
    "version": { "$ref": "#/$defs/semver" },
    "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "runtime_target": {
      "oneOf": [
        { "type": "string", "enum": ["darwin/amd64", "darwin/arm64", "linux/amd64", "linux/arm64"] },
        { "type": "null" }
      ]
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "compatibility_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "npm_package": { "$ref": "#/$defs/npm_package" },
    "worker_sdk": { "$ref": "#/$defs/worker_sdk" },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/file" }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "npm_package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "path", "sha256", "integrity", "size"],
      "properties": {
        "name": { "const": "@floegence/redevplugin-ui" },
        "version": { "$ref": "#/$defs/semver" },
        "path": { "type": "string", "pattern": "^npm/floegence-redevplugin-ui-[A-Za-z0-9._+-]+\\.tgz$" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "integrity": { "type": "string", "pattern": "^sha512-[A-Za-z0-9+/]+={0,2}$" },
        "size": { "type": "integer", "minimum": 1 }
      }
    },
    "worker_sdk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "path", "sha256", "size"],
      "properties": {
        "name": { "const": "redevplugin-worker-sdk" },
        "version": { "$ref": "#/$defs/semver" },
        "path": { "type": "string", "pattern": "^sdk/redevplugin-worker-sdk-[A-Za-z0-9._+-]+\\.crate$" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "size": { "type": "integer", "minimum": 1 }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._/@+-]+$",
          "not": {
            "anyOf": [
              { "pattern": "^/" },
              { "pattern": "(^|/)\\.\\.(/|$)" },
              { "pattern": "\\\\" }
            ]
          }
        },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "size": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
