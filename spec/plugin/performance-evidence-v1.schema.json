{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/performance-evidence-v1.schema.json",
  "title": "ReDevPlugin release performance evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_version",
    "source_commit",
    "generated_at",
    "environment",
    "scenarios",
    "contract_hashes"
  ],
  "properties": {
    "schema_version": { "const": "redevplugin.performance_evidence.v1" },
    "release_version": { "$ref": "#/$defs/semver" },
    "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "generated_at": { "type": "string", "format": "date-time" },
    "environment": { "$ref": "#/$defs/environment" },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/scenario" }
    },
    "contract_hashes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/contract_hash" }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch", "logical_cpus", "go_version", "node_version", "rustc_version"],
      "properties": {
        "os": { "type": "string", "minLength": 1 },
        "arch": { "type": "string", "minLength": 1 },
        "logical_cpus": { "type": "integer", "minimum": 1 },
        "go_version": { "type": "string", "minLength": 1 },
        "node_version": { "type": "string", "minLength": 1 },
        "rustc_version": { "type": "string", "minLength": 1 },
        "chromium_version": { "type": "string", "minLength": 1 }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "gate", "status", "sample_count", "metrics"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]+$" },
        "gate": { "enum": ["fast", "weekly", "full", "release"] },
        "status": { "const": "pass" },
        "sample_count": { "type": "integer", "minimum": 1 },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/metric" }
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "unit", "observed", "limit", "comparator"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9._-]+$" },
        "unit": { "enum": ["milliseconds", "count", "bytes", "queries", "long_tasks"] },
        "observed": { "type": "number", "minimum": 0 },
        "limit": { "type": "number", "minimum": 0 },
        "comparator": { "enum": ["lte", "eq"] }
      }
    },
    "contract_hash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
