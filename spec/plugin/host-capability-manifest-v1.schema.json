{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/host-capability-manifest-v1.schema.json",
  "title": "ReDevPlugin host capability artifact manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "publisher_id",
    "contract_id",
    "contract_version",
    "capability_id",
    "capability_version",
    "generated_at",
    "source_commit",
    "signature_algorithm",
    "signature_key_id",
    "signature_policy_epoch",
    "signature_revocation_epoch",
    "entries"
  ],
  "properties": {
    "schema_version": { "const": "redevplugin.host_capability_manifest.v1" },
    "publisher_id": { "$ref": "#/$defs/id" },
    "contract_id": { "$ref": "#/$defs/id" },
    "contract_version": { "$ref": "#/$defs/semver" },
    "capability_id": { "$ref": "#/$defs/id" },
    "capability_version": { "$ref": "#/$defs/semver" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "signature_algorithm": { "const": "ed25519" },
    "signature_key_id": { "$ref": "#/$defs/id" },
    "signature_policy_epoch": { "$ref": "#/$defs/decimal_epoch" },
    "signature_revocation_epoch": { "$ref": "#/$defs/decimal_epoch" },
    "entries": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "$ref": "#/$defs/entry" },
      "allOf": [
        { "contains": { "properties": { "role": { "const": "contract" } }, "required": ["role"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "role": { "const": "compatibility" } }, "required": ["role"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "role": { "const": "generated_client" } }, "required": ["role"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "role": { "const": "notices" } }, "required": ["role"] }, "minContains": 1, "maxContains": 1 }
      ]
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "artifact_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^[A-Za-z0-9._~-]+(?:/[A-Za-z0-9._~-]+)*$",
      "not": { "pattern": "(^|/)\\.{1,2}($|/)" }
    },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "decimal_epoch": { "type": "string", "pattern": "^(0|[1-9][0-9]*)$" },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "ref", "media_type", "sha256", "size"],
      "properties": {
        "role": { "enum": ["contract", "compatibility", "generated_client", "notices"] },
        "ref": { "$ref": "#/$defs/artifact_ref" },
        "media_type": { "enum": ["application/schema+json", "application/json", "text/typescript"] },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size": { "type": "integer", "minimum": 0 }
      },
      "allOf": [
        {
          "if": { "properties": { "role": { "const": "contract" } }, "required": ["role"] },
          "then": { "properties": { "media_type": { "const": "application/schema+json" } } }
        },
        {
          "if": { "properties": { "role": { "enum": ["compatibility", "notices"] } }, "required": ["role"] },
          "then": { "properties": { "media_type": { "const": "application/json" } } }
        },
        {
          "if": { "properties": { "role": { "const": "generated_client" } }, "required": ["role"] },
          "then": { "properties": { "media_type": { "const": "text/typescript" } } }
        }
      ]
    }
  }
}
