{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/release-metadata-v5.schema.json",
  "title": "ReDevPlugin signed plugin release metadata v5",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_id",
    "release_metadata_ref",
    "publisher_id",
    "plugin_id",
    "version",
    "distribution_ref",
    "hashes",
    "release_metadata_signature",
    "package_signature",
    "compatibility"
  ],
  "properties": {
    "schema_version": { "const": "redevplugin.release_metadata.v5" },
    "source_id": { "type": "string", "minLength": 1 },
    "release_metadata_ref": { "$ref": "#/$defs/artifact_ref" },
    "publisher_id": { "type": "string", "minLength": 1 },
    "plugin_id": { "type": "string", "minLength": 1 },
    "version": { "$ref": "#/$defs/semver" },
    "distribution_ref": { "$ref": "#/$defs/distribution_ref" },
    "hashes": { "$ref": "#/$defs/package_hash_set" },
    "release_metadata_signature": { "$ref": "#/$defs/release_metadata_signature" },
    "package_signature": { "$ref": "#/$defs/package_release_signature" },
    "compatibility": { "$ref": "#/$defs/release_compatibility" },
    "host_requirements": {
      "type": "array",
      "items": { "$ref": "#/$defs/host_requirement" }
    },
    "release_evidence": { "$ref": "#/$defs/release_evidence" },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "artifact_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._/@+-]+$",
      "not": {
        "anyOf": [
          { "pattern": "^/" },
          { "pattern": "(^|/)\\.\\.(/|$)" },
          { "pattern": "\\\\" },
          { "pattern": "[?#]" }
        ]
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "distribution_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["distribution", "artifact_ref"],
      "properties": {
        "distribution": { "enum": ["registry_ref", "host_artifact_ref"] },
        "artifact_ref": { "$ref": "#/$defs/artifact_ref" }
      }
    },
    "package_hash_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package_sha256", "manifest_sha256", "entries_sha256"],
      "properties": {
        "package_sha256": { "$ref": "#/$defs/sha256" },
        "manifest_sha256": { "$ref": "#/$defs/sha256" },
        "entries_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "release_metadata_signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "signature_ref", "source_policy_epoch", "revocation_epoch"],
      "properties": {
        "algorithm": { "enum": ["ed25519"] },
        "key_id": { "type": "string", "minLength": 1 },
        "signature_ref": { "$ref": "#/$defs/artifact_ref" },
        "source_policy_epoch": { "$ref": "#/$defs/decimal_epoch" },
        "revocation_epoch": { "$ref": "#/$defs/decimal_epoch" }
      }
    },
    "package_release_signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "signature_bundle_ref", "source_policy_epoch", "revocation_epoch"],
      "properties": {
        "algorithm": { "enum": ["ed25519"] },
        "key_id": { "type": "string", "minLength": 1 },
        "signature_bundle_ref": { "$ref": "#/$defs/artifact_ref" },
        "source_policy_epoch": { "$ref": "#/$defs/decimal_epoch" },
        "revocation_epoch": { "$ref": "#/$defs/decimal_epoch" }
      }
    },
    "release_compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_redevplugin_version", "min_runtime_version", "ui_protocol_version"],
      "properties": {
        "min_redevplugin_version": { "$ref": "#/$defs/semver" },
        "min_runtime_version": { "$ref": "#/$defs/semver" },
        "ui_protocol_version": { "const": "plugin-ui-v5" },
        "supported_targets": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["darwin/amd64", "darwin/arm64", "linux/amd64", "linux/arm64"] }
        }
      }
    },
    "host_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host_id"],
      "properties": {
        "host_id": { "type": "string", "minLength": 1 },
        "min_host_version": { "$ref": "#/$defs/semver" },
        "required_capability_contracts": {
          "type": "array",
          "items": { "$ref": "#/$defs/host_capability_requirement" }
        }
      }
    },
    "host_capability_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_id",
        "capability_version",
        "contract"
      ],
      "properties": {
        "capability_id": { "type": "string", "minLength": 1 },
        "capability_version": { "$ref": "#/$defs/semver" },
        "contract": { "$ref": "#/$defs/host_capability_contract_ref" }
      }
    },
    "host_capability_contract_ref": {
      "$ref": "host-capability-pin-v1.schema.json"
    },
    "release_evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "notices_sha256": { "$ref": "#/$defs/sha256" },
        "provenance_sha256": { "$ref": "#/$defs/sha256" },
        "generated_at": { "type": "string", "format": "date-time" }
      }
    },
    "decimal_epoch": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)$"
    }
  }
}
