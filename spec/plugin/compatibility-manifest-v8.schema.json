{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/compatibility-manifest-v8.schema.json",
  "title": "ReDevPlugin compatibility manifest v8",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "package_set", "matrix", "contract_set_sha256", "contracts"],
  "properties": {
    "schema_version": {"const": "redevplugin.compatibility.v8"},
    "package_set": {"$ref": "platform-package-set-v1.schema.json"},
    "matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_ui_protocol_version", "plugin_host_protocol_version", "rust_ipc_version", "wasm_abi_version",
        "manifest_schema_version", "package_signature_schema_version", "release_metadata_schema_version",
        "release_root_delegation_schema_version", "release_source_policy_schema_version",
        "release_source_policy_pointer_schema_version", "release_revocation_schema_version",
        "release_revocation_pointer_schema_version", "release_trust_state_schema_version",
        "trusted_time_evidence_schema_version", "trusted_time_leaf_schema_version",
        "release_signing_ledger_schema_version", "release_signing_subject_schema_version",
        "release_signature_envelope_schema_version", "release_signing_ledger_receipt_schema_version",
        "release_signing_ledger_evidence_schema_version", "token_ticket_schema_version", "bridge_schema_version",
        "opaque_surface_document_schema_version", "opaque_surface_transport_schema_version", "target_classifier_version",
        "network_grant_schema_version", "resource_scope_schema_version", "session_scope_schema_version",
        "plugin_platform_openapi_version", "compatibility_schema_version", "worker_invocation_schema_version",
        "host_capability_contract_schema_version", "host_capability_pin_schema_version",
        "host_capability_manifest_schema_version", "host_capability_compatibility_schema_version",
        "host_capability_signature_schema_version", "host_capability_notices_schema_version",
        "error_codes_schema_version", "performance_contract_version", "performance_evidence_schema_version",
        "contract_registry_version", "platform_package_set_schema_version",
        "platform_package_publication_schema_version", "runtime_admission_schema_version",
        "runtime_descriptor_schema_version", "owner_scope_inventory_registry_version",
        "owner_scope_inventory_schema_version", "owner_scope_migration_schema_version",
        "process_containment_schema_version", "runtime_exec_journal_schema_version",
        "quarantine_cleanup_schema_version"
      ],
      "properties": {
        "plugin_ui_protocol_version": {"const": "plugin-ui-v5"},
        "plugin_host_protocol_version": {"const": "plugin-host-v6"},
        "rust_ipc_version": {"const": "rust-ipc-v6"},
        "wasm_abi_version": {"const": "redevplugin-wasm-worker-v2"},
        "manifest_schema_version": {"const": "manifest-v5"},
        "package_signature_schema_version": {"const": "package-signature-v1"},
        "release_metadata_schema_version": {"const": "release-metadata-v5"},
        "release_root_delegation_schema_version": {"const": "release-root-delegation-v1"},
        "release_source_policy_schema_version": {"const": "release-source-policy-v2"},
        "release_source_policy_pointer_schema_version": {"const": "release-source-policy-pointer-v1"},
        "release_revocation_schema_version": {"const": "release-revocation-v2"},
        "release_revocation_pointer_schema_version": {"const": "release-revocation-pointer-v1"},
        "release_trust_state_schema_version": {"const": "release-trust-state-v1"},
        "trusted_time_evidence_schema_version": {"const": "trusted-time-evidence-v1"},
        "trusted_time_leaf_schema_version": {"const": "trusted-time-leaf-v1"},
        "release_signing_ledger_schema_version": {"const": "release-signing-ledger-v1"},
        "release_signing_subject_schema_version": {"const": "release-signing-subject-v1"},
        "release_signature_envelope_schema_version": {"const": "release-signature-envelope-v1"},
        "release_signing_ledger_receipt_schema_version": {"const": "release-signing-ledger-receipt-v1"},
        "release_signing_ledger_evidence_schema_version": {"const": "release-signing-ledger-evidence-v1"},
        "token_ticket_schema_version": {"const": "token-ticket-v4"},
        "bridge_schema_version": {"const": "bridge-v5"},
        "opaque_surface_document_schema_version": {"const": "opaque-surface-document-v3"},
        "opaque_surface_transport_schema_version": {"const": "opaque-surface-transport-v4"},
        "target_classifier_version": {"const": "target-classifier-v2"},
        "network_grant_schema_version": {"const": "network-grant-v2"},
        "resource_scope_schema_version": {"const": "resource-scope-v1"},
        "session_scope_schema_version": {"const": "session-scope-v1"},
        "plugin_platform_openapi_version": {"const": "plugin-platform-v8"},
        "compatibility_schema_version": {"const": "compatibility-manifest-v8"},
        "worker_invocation_schema_version": {"const": "worker-invocation-v3"},
        "host_capability_contract_schema_version": {"const": "host-capability-contract-v1"},
        "host_capability_pin_schema_version": {"const": "host-capability-pin-v1"},
        "host_capability_manifest_schema_version": {"const": "host-capability-manifest-v1"},
        "host_capability_compatibility_schema_version": {"const": "host-capability-compatibility-v1"},
        "host_capability_signature_schema_version": {"const": "host-capability-signature-v1"},
        "host_capability_notices_schema_version": {"const": "host-capability-notices-v1"},
        "error_codes_schema_version": {"const": "error-codes-v6"},
        "performance_contract_version": {"const": "performance-contract-v4"},
        "performance_evidence_schema_version": {"const": "performance-evidence-v4"},
        "contract_registry_version": {"const": "contract-registry-v2"},
        "platform_package_set_schema_version": {"const": "platform-package-set-v1"},
        "platform_package_publication_schema_version": {"const": "platform-package-publication-v1"},
        "runtime_admission_schema_version": {"const": "runtime-admission-v1"},
        "runtime_descriptor_schema_version": {"const": "runtime-descriptor-v2"},
        "owner_scope_inventory_registry_version": {"const": "owner-scope-inventory-registry-v1"},
        "owner_scope_inventory_schema_version": {"const": "owner-scope-inventory-v1"},
        "owner_scope_migration_schema_version": {"const": "owner-scope-migration-v1"},
        "process_containment_schema_version": {"const": "process-containment-v1"},
        "runtime_exec_journal_schema_version": {"const": "runtime-exec-journal-v1"},
        "quarantine_cleanup_schema_version": {"const": "quarantine-cleanup-v1"}
      }
    },
    "contract_set_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "contracts": {
      "type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true,
      "items": {"$ref": "#/$defs/contract"}
    }
  },
  "$defs": {
    "contract": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "path", "version", "sha256"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]+$"},
        "path": {"type": "string", "pattern": "^spec/(openapi|plugin)/[A-Za-z0-9._/-]+$"},
        "version": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
