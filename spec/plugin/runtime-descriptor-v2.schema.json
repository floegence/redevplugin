{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/runtime-descriptor-v2.schema.json",
  "title": "ReDevPlugin runtime descriptor v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "platform_version", "target", "rust_ipc_version", "wasm_abi_version", "contract_set_sha256", "binary_sha256"],
  "properties": {
    "schema_version": {"const": "runtime-descriptor-v2"},
    "platform_version": {"$ref": "#/$defs/semver"},
    "target": {"type": "string", "enum": ["linux/amd64", "linux/arm64"]},
    "rust_ipc_version": {"const": "rust-ipc-v6"},
    "wasm_abi_version": {"const": "redevplugin-wasm-worker-v2"},
    "contract_set_sha256": {"$ref": "#/$defs/sha256"},
    "binary_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "semver": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
