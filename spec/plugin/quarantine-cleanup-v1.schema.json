{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.redevplugin.dev/plugin/quarantine-cleanup-v1.schema.json",
  "title": "ReDevPlugin quarantine cleanup journal v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "migration_id",
    "root_identity_sha256",
    "quarantine_id",
    "quarantine_sha256",
    "state",
    "entries"
  ],
  "properties": {
    "schema_version": { "const": "quarantine-cleanup-v1" },
    "migration_id": { "type": "string", "pattern": "^migration_[0-9a-f]{32}$" },
    "root_identity_sha256": { "$ref": "#/$defs/sha256" },
    "quarantine_id": { "type": "string", "pattern": "^quarantine_[0-9a-f]{32}$" },
    "quarantine_sha256": { "$ref": "#/$defs/sha256" },
    "state": { "enum": ["delete_prepared", "deleting", "delete_reconcile_required", "deleted"] },
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200000,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind", "device", "inode", "uid", "mode", "size", "nlink", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^[^/\\\\]+(?:/[^/\\\\]+)*$",
          "not": { "pattern": "(^|/)\\.\\.?($|/)" }
        },
        "kind": { "enum": ["directory", "file"] },
        "device": { "type": "integer", "minimum": 0, "maximum": 18446744073709551615 },
        "inode": { "type": "integer", "minimum": 1, "maximum": 18446744073709551615 },
        "uid": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "mode": { "type": "integer", "minimum": 0, "maximum": 4095 },
        "size": { "type": "integer", "minimum": 0, "maximum": 4294967296 },
        "nlink": { "type": "integer", "minimum": 0, "maximum": 1 },
        "sha256": { "type": "string", "pattern": "^$|^[0-9a-f]{64}$" }
      }
    }
  }
}
