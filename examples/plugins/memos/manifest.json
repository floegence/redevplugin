{
  "schema_version": "redevplugin.manifest.v3",
  "publisher": { "publisher_id": "dev.redevplugin.examples", "display_name": "ReDevPlugin Examples" },
  "plugin": {
    "plugin_id": "dev.redevplugin.examples.memos",
    "display_name": "Memos",
    "version": "1.1.0",
    "api_version": "plugin-v1",
    "min_runtime_version": "0.4.0",
    "ui_protocol_version": "plugin-ui-v3"
  },
  "surfaces": [{
    "surface_id": "memos.view",
    "kind": "view",
    "intent": "primary",
    "label": "Memos",
    "entry": "ui/index.html",
    "default_size": { "width": 1040, "height": 720 }
  }],
  "workers": [{
    "worker_id": "memos_backend",
    "artifact": "workers/memos.wasm",
    "abi": "redevplugin-wasm-worker-v2",
    "mode": "job",
    "scope": "user",
    "memory_limit_bytes": 33554432
  }],
  "methods": [
    {
      "method": "memos.initialize",
      "effect": "write",
      "execution": "sync",
      "route": { "kind": "worker", "worker_id": "memos_backend", "export": "redevplugin_worker_invoke" },
      "request_schema": { "type": "object", "additionalProperties": false, "properties": {} },
      "response_schema": { "type": "object", "additionalProperties": false, "required": ["ready"], "properties": { "ready": { "type": "boolean", "const": true } } },
      "broker_access": { "storage": [{ "store_id": "memos", "operations": ["exec"] }] }
    },
    {
      "method": "memos.list",
      "effect": "read",
      "execution": "sync",
      "route": { "kind": "worker", "worker_id": "memos_backend", "export": "redevplugin_worker_invoke" },
      "request_schema": {
        "type": "object", "additionalProperties": false,
        "properties": {
          "query": { "type": "string", "maxLength": 200 },
          "offset": { "type": "integer", "minimum": 0, "maximum": 100000 },
          "limit": { "type": "integer", "minimum": 1, "maximum": 30 },
          "pinned_only": { "type": "boolean" }
        }
      },
      "response_schema": {
        "type": "object", "additionalProperties": false, "required": ["notes", "total", "offset", "has_more"],
        "properties": {
          "notes": { "type": "array", "maxItems": 30, "items": { "$ref": "#/$defs/note" } },
          "total": { "type": "integer", "minimum": 0 },
          "offset": { "type": "integer", "minimum": 0 },
          "has_more": { "type": "boolean" }
        },
        "$defs": {
          "note": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "title", "preview", "pinned", "created_at", "updated_at"],
            "properties": {
              "id": { "type": "string" }, "title": { "type": "string" }, "preview": { "type": "string" },
              "pinned": { "type": "boolean" }, "created_at": { "type": "string" }, "updated_at": { "type": "string" }
            }
          }
        }
      },
      "broker_access": { "storage": [{ "store_id": "memos", "operations": ["query"] }] }
    },
    {
      "method": "memos.get",
      "effect": "read",
      "execution": "sync",
      "route": { "kind": "worker", "worker_id": "memos_backend", "export": "redevplugin_worker_invoke" },
      "request_schema": { "type": "object", "additionalProperties": false, "required": ["id"], "properties": { "id": { "type": "string" } } },
      "response_schema": {
        "type": "object", "additionalProperties": false, "required": ["note"],
        "properties": { "note": { "$ref": "#/$defs/note" } },
        "$defs": {
          "note": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "title", "body", "pinned", "created_at", "updated_at"],
            "properties": {
              "id": { "type": "string" }, "title": { "type": "string" }, "body": { "type": "string" },
              "pinned": { "type": "boolean" }, "created_at": { "type": "string" }, "updated_at": { "type": "string" }
            }
          }
        }
      },
      "broker_access": { "storage": [{ "store_id": "memos", "operations": ["query"] }] }
    },
    {
      "method": "memos.save",
      "effect": "write",
      "execution": "sync",
      "route": { "kind": "worker", "worker_id": "memos_backend", "export": "redevplugin_worker_invoke" },
      "request_schema": {
        "type": "object", "additionalProperties": false, "required": ["title", "body"],
        "properties": {
          "id": { "type": "string" }, "title": { "type": "string", "minLength": 1, "maxLength": 160 },
          "body": { "type": "string", "maxLength": 20000 }, "pinned": { "type": "boolean" }
        }
      },
      "response_schema": {
        "type": "object", "additionalProperties": false, "required": ["note"],
        "properties": { "note": { "$ref": "#/$defs/note" } },
        "$defs": {
          "note": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "title", "body", "pinned", "created_at", "updated_at"],
            "properties": {
              "id": { "type": "string" }, "title": { "type": "string" }, "body": { "type": "string" },
              "pinned": { "type": "boolean" }, "created_at": { "type": "string" }, "updated_at": { "type": "string" }
            }
          }
        }
      },
      "broker_access": { "storage": [{ "store_id": "memos", "operations": ["exec", "query"] }] }
    },
    {
      "method": "memos.delete",
      "effect": "delete",
      "execution": "sync",
      "route": { "kind": "worker", "worker_id": "memos_backend", "export": "redevplugin_worker_invoke" },
      "request_schema": { "type": "object", "additionalProperties": false, "required": ["id"], "properties": { "id": { "type": "string" } } },
      "response_schema": { "type": "object", "additionalProperties": false, "required": ["deleted_id"], "properties": { "deleted_id": { "type": "string" } } },
      "broker_access": { "storage": [{ "store_id": "memos", "operations": ["exec"] }] }
    },
    {
      "method": "memos.togglePin",
      "effect": "write",
      "execution": "sync",
      "route": { "kind": "worker", "worker_id": "memos_backend", "export": "redevplugin_worker_invoke" },
      "request_schema": { "type": "object", "additionalProperties": false, "required": ["id"], "properties": { "id": { "type": "string" } } },
      "response_schema": {
        "type": "object", "additionalProperties": false, "required": ["note"],
        "properties": { "note": { "$ref": "#/$defs/note" } },
        "$defs": {
          "note": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "title", "body", "pinned", "created_at", "updated_at"],
            "properties": {
              "id": { "type": "string" }, "title": { "type": "string" }, "body": { "type": "string" },
              "pinned": { "type": "boolean" }, "created_at": { "type": "string" }, "updated_at": { "type": "string" }
            }
          }
        }
      },
      "broker_access": { "storage": [{ "store_id": "memos", "operations": ["exec", "query"] }] }
    }
  ],
  "storage": { "stores": [{
    "store_id": "memos", "kind": "sqlite", "scope": "user", "quota_bytes": 8388608, "quota_files": 8,
    "schema_version": 1,
    "migration": {
      "from_version": 0, "to_version": 1, "reversible": true, "requires_worker": true,
      "estimated_bytes": 0, "max_duration_ms": 2000, "data_loss_risk": false,
      "steps_hash": "sha256:redevplugin-example-memos-worker-migration-v1"
    }
  }] }
}
