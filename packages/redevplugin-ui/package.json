{
  "name": "@floegence/redevplugin-ui",
  "version": "0.0.0-dev",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/floegence/redevplugin.git",
    "directory": "packages/redevplugin-ui"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./trusted-parent": {
      "types": "./dist/trusted-parent.d.ts",
      "default": "./dist/trusted-parent.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./local-import": {
      "types": "./dist/local-import.d.ts",
      "default": "./dist/local-import.js"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@floegence/redevplugin-contracts": "0.6.13"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/*.js"
  }
}
